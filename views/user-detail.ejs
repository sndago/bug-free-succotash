<script src="/js/modal.js"></script>
<script>
  async function handleUserPhotoUpload(input) {
    const file = input.files[0];
    if (!file) return;

    const avatar = document.getElementById('udAvatar');

    // Optimistic preview
    const reader = new FileReader();
    reader.onload = e => {
      let img = document.getElementById('udAvatarImg');
      const initials = document.getElementById('udAvatarInitials');
      if (!img) {
        img = document.createElement('img');
        img.id = 'udAvatarImg';
        img.className = 'ud-avatar-img';
        img.alt = '';
        const cam = document.getElementById('udAvatarCam');
        if (initials) initials.replaceWith(img);
        else avatar.insertBefore(img, cam);
      }
      img.src = e.target.result;
    };
    reader.readAsDataURL(file);

    avatar.classList.add('loading');

    const fd = new FormData();
    fd.append('photo', file);
    try {
      const res  = await fetch('/users/<%= targetUser._id %>/photo', { method: 'POST', body: fd });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Upload failed');
      const img = document.getElementById('udAvatarImg');
      if (img) img.src = data.photo + '?t=' + Date.now();
    } catch (err) {
      alert('Photo upload failed: ' + err.message);
    } finally {
      avatar.classList.remove('loading');
      input.value = '';
    }
  }
</script>
