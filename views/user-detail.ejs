<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cone — <%= targetUser.name %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/client.css">
</head>
<body>
<%
  const roleLabels   = { super_admin: 'Super Admin', admin: 'Admin', teller: 'Teller' };
  const isSuperAdmin = user.role === 'super_admin';
  const isTeller     = targetUser.role === 'teller';
  const initials     = targetUser.name.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase();
  const fmtDate      = d => new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  const fmtRelative  = d => {
    const diff = Date.now() - new Date(d);
    const mins = Math.floor(diff / 60000);
    if (mins < 1)   return 'just now';
    if (mins < 60)  return mins + 'm ago';
    const hrs = Math.floor(mins / 60);
    if (hrs < 24)   return hrs + 'h ago';
    const days = Math.floor(hrs / 24);
    if (days < 30)  return days + 'd ago';
    return fmtDate(d);
  };
  const actionIcons = {
    CLIENT_CREATE:   '#10b981', CLIENT_UPDATE: '#6366f1', CLIENT_DELETE: '#ef4444', CLIENT_APPROVE: '#10b981', CLIENT_REJECT: '#ef4444',
    TXN_CREATE:      '#6366f1', TXN_UPDATE:    '#6366f1', TXN_APPROVE:   '#10b981', TXN_REJECT:     '#ef4444',
    USER_CREATE:     '#6366f1', USER_UPDATE:   '#6366f1', USER_DELETE:   '#ef4444',
    BRANCH_CREATE:   '#6366f1', LOGIN:         '#94a3b8', LOGOUT:        '#94a3b8',
  };
  const perfColors = { indigo: '#6366f1', green: '#10b981', blue: '#3b82f6', amber: '#f59e0b' };
  const perfBg     = { indigo: '#eef2ff', green: '#ecfdf5', blue: '#eff6ff', amber: '#fffbeb' };
%>
<div class="layout">

  <!-- ── Sidebar ──────────────────────────────── -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <svg viewBox="0 0 40 40" width="26" height="26" fill="none">
        <polygon points="20,3 38,37 2,37" fill="#6366f1"/>
      </svg>
      <span class="logo-text">CONE</span>
    </div>
    <nav class="sidebar-nav">
      <a href="/dashboard" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
        Dashboard
      </a>
      <a href="/clients" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        Clients
      </a>
      <a href="/transactions" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <line x1="17" y1="7" x2="7" y2="7"/>
          <polyline points="14 4 17 7 14 10"/>
          <line x1="7" y1="17" x2="17" y2="17"/>
          <polyline points="10 14 7 17 10 20"/>
        </svg>
        Transactions
      </a>
      <a href="/requests" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
        </svg>
        Requests
      </a>
      <a href="/users" class="nav-link active">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <line x1="23" y1="11" x2="17" y2="11"/><line x1="20" y1="8" x2="20" y2="14"/>
        </svg>
        Staff
      </a>
      <a href="/logs" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
        </svg>
        Logs
      </a>
      <a href="/branches" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        Branches
      </a>
      <% if (isSuperAdmin) { %>
      <a href="/archive" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <polyline points="21 8 21 21 3 21 3 8"/>
          <rect x="1" y="3" width="22" height="5"/>
          <line x1="10" y1="12" x2="14" y2="12"/>
        </svg>
        Archive
      </a>
      <% } %>
    </nav>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.name[0].toUpperCase() %></div>
      <div class="user-info">
        <div class="user-name"><%= user.name %></div>
        <span class="role-badge <%= user.role %>"><%= roleLabels[user.role] || user.role %></span>
      </div>
    </div>
  </aside>

  <!-- ── Main Content ──────────────────────────── -->
  <div class="main-content">
    <header class="topbar">
      <div class="topbar-breadcrumb">
        <a href="/dashboard" class="back-link">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          Dashboard
        </a>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" class="breadcrumb-sep">
          <path d="M9 18l6-6-6-6"/>
        </svg>
        <a href="/users" class="back-link">Staff</a>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" class="breadcrumb-sep">
          <path d="M9 18l6-6-6-6"/>
        </svg>
        <span class="breadcrumb-current"><%= targetUser.name %></span>
      </div>
      <form action="/logout" method="POST">
        <button type="submit" class="btn-logout">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
          Sign out
        </button>
      </form>
    </header>

    <div class="page-content">

      <!-- ── Profile card ──────────────────────── -->
      <div class="ud-profile-card">
        <div class="ud-avatar" id="udAvatar" title="Click to upload photo" onclick="document.getElementById('udPhotoInput').click()">
          <% if (targetUser.photo) { %>
          <img src="<%= targetUser.photo %>" alt="<%= targetUser.name %>" class="ud-avatar-img" id="udAvatarImg">
          <% } else { %>
          <span id="udAvatarInitials" style="font-size:1.375rem;font-weight:700;color:<%= targetUser.isActive ? '#fff' : '#94a3b8' %>;letter-spacing:-.02em"><%= initials %></span>
          <% } %>
          <div class="ud-avatar-cam" id="udAvatarCam">
            <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
              <circle cx="12" cy="13" r="4"/>
            </svg>
          </div>
          <input type="file" id="udPhotoInput" accept="image/jpeg,image/png,image/webp,image/gif"
                 style="display:none" onchange="handleUserPhotoUpload(this)">
        </div>
        <div class="ud-profile-body">
          <div class="ud-profile-top">
            <div class="ud-profile-title">
              <h1 class="ud-name"><%= targetUser.name %></h1>
              <div class="ud-badges">
                <span class="role-badge <%= targetUser.role %>"><%= roleLabels[targetUser.role] %></span>
                <% if (targetUser.isActive) { %>
                <span class="approval-badge approval-approved">Active</span>
                <% } else { %>
                <span class="approval-badge approval-rejected">Inactive</span>
                <% } %>
              </div>
            </div>
            <div class="ud-actions">
              <a href="/users/<%= targetUser._id %>/edit" class="ud-btn ud-btn-default">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                Edit
              </a>
              <form action="/users/<%= targetUser._id %>/toggle" method="POST"
                    data-confirm="<%= targetUser.isActive ? 'Deactivate' : 'Reactivate' %> <%= targetUser.name %>?"
                    data-confirm-title="<%= targetUser.isActive ? 'Deactivate' : 'Reactivate' %> Staff"
                    data-confirm-variant="<%= targetUser.isActive ? 'warning' : 'primary' %>"
                    data-confirm-ok="<%= targetUser.isActive ? 'Deactivate' : 'Reactivate' %>">
                <button type="submit" class="ud-btn <%= targetUser.isActive ? 'ud-btn-warn' : 'ud-btn-success' %>">
                  <% if (targetUser.isActive) { %>
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
                  </svg>
                  Deactivate
                  <% } else { %>
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  Reactivate
                  <% } %>
                </button>
              </form>
            </div>
          </div>
          <div class="hero-meta">
            <% if (targetUser.staffId) { %>
            <span class="meta-chip mono">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 3h-8a2 2 0 0 0-2 2v2h12V5a2 2 0 0 0-2-2z"/>
              </svg>
              ID: <%= targetUser.staffId %>
            </span>
            <% } %>
            <span class="meta-chip">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/>
              </svg>
              <%= targetUser.email %>
            </span>
            <% if (targetUser.phone) { %>
            <span class="meta-chip mono">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.65 3.38 2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.84a16 16 0 0 0 6.29 6.29l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              <%= targetUser.phone %>
            </span>
            <% } %>
            <% if (targetUser.branch) { %>
            <span class="meta-chip">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                <polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
              <%= targetUser.branch.name %><%= targetUser.branch.code ? ` · ${targetUser.branch.code}` : '' %>
            </span>
            <% } %>
            <span class="meta-chip">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
              Joined <%= fmtDate(targetUser.createdAt) %>
            </span>
          </div>
        </div>
      </div>

      <!-- ── Two-column grid ───────────────────── -->
      <div class="ud-grid">

        <!-- Account Details -->
        <div class="table-card ud-card">
          <div class="ud-card-header">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#6366f1" stroke-width="1.75">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
            Account Details
          </div>
          <dl class="detail-list">
            <div class="detail-row"><dt>Full Name</dt><dd><%= targetUser.name %></dd></div>
            <div class="detail-row"><dt>Email</dt><dd><%= targetUser.email %></dd></div>
            <% if (targetUser.phone) { %>
            <div class="detail-row"><dt>Phone</dt><dd class="mono"><%= targetUser.phone %></dd></div>
            <% } %>
            <div class="detail-row">
              <dt>Role</dt>
              <dd><span class="role-badge <%= targetUser.role %>" style="font-size:.72rem"><%= roleLabels[targetUser.role] %></span></dd>
            </div>
            <% if (targetUser.staffId) { %>
            <div class="detail-row"><dt>Staff ID</dt><dd class="mono"><%= targetUser.staffId %></dd></div>
            <% } %>
            <% if (targetUser.branch) { %>
            <div class="detail-row"><dt>Branch</dt><dd><%= targetUser.branch.name %><%= targetUser.branch.code ? ` (${targetUser.branch.code})` : '' %></dd></div>
            <% } %>
            <div class="detail-row">
              <dt>Status</dt>
              <dd>
                <% if (targetUser.isActive) { %>
                <span class="approval-badge approval-approved">Active</span>
                <% } else { %>
                <span class="approval-badge approval-rejected">Inactive</span>
                <% } %>
              </dd>
            </div>
            <div class="detail-row"><dt>Member Since</dt><dd><%= fmtDate(targetUser.createdAt) %></dd></div>
          </dl>
        </div>

        <!-- Performance -->
        <div class="table-card ud-card">
          <div class="ud-card-header">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#f59e0b" stroke-width="1.75">
              <circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>
            </svg>
            Performance
          </div>

          <div class="ud-perf-badge" style="background:<%= perfBg[perfColor] %>">
            <div class="ud-perf-icon" style="background:<%= perfColors[perfColor] %>">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#fff" stroke-width="1.75">
                <circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>
              </svg>
            </div>
            <div>
              <div class="ud-perf-title" style="color:<%= perfColors[perfColor] %>"><%= perfScore %></div>
              <div class="ud-perf-sub"><%= thisMonthTxns %> transaction<%= thisMonthTxns !== 1 ? 's' : '' %> this month</div>
            </div>
          </div>

          <div class="ud-tier-list">
            <%
              const tiers = [
                { label: 'Top Performer',  min: 50, color: '#6366f1' },
                { label: 'High Performer', min: 20, color: '#10b981' },
                { label: 'Good Standing',  min: 5,  color: '#3b82f6' },
                { label: 'Getting Started',min: 0,  color: '#f59e0b' },
              ];
              tiers.forEach(tier => { const active = perfScore === tier.label; %>
            <div class="ud-tier-row <%= active ? 'ud-tier-active' : '' %>">
              <span class="ud-tier-dot" style="background:<%= tier.color %>"></span>
              <span class="ud-tier-label" style="<%= active ? `color:${tier.color};font-weight:600` : '' %>"><%= tier.label %></span>
              <span class="ud-tier-min"><%= tier.min %>+ txns/mo</span>
            </div>
            <% }) %>
          </div>
        </div>

      </div>

      <!-- ── Referees / Emergency Contacts ───────── -->
      <% if (targetUser.referees && targetUser.referees.length) { %>
      <div class="ud-ref-section">
        <div class="ud-ref-heading">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#6366f1" stroke-width="1.75">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
          Referees / Emergency Contacts
        </div>
        <div class="ud-ref-grid">
          <% targetUser.referees.forEach((ref, i) => { %>
          <div class="table-card ud-card">
            <div class="ud-card-header">
              <span class="ud-ref-num"><%= i + 1 %></span>
              Referee <%= i + 1 %>
              <% if (ref.relationship) { %>
              <span class="ud-ref-rel"><%= ref.relationship %></span>
              <% } %>
            </div>
            <dl class="detail-list">
              <div class="detail-row"><dt>Name</dt><dd><%= ref.name %></dd></div>
              <div class="detail-row"><dt>Phone</dt><dd class="mono"><%= ref.phone %></dd></div>
              <% if (ref.email) { %>
              <div class="detail-row"><dt>Email</dt><dd><%= ref.email %></dd></div>
              <% } %>
            </dl>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>

    </div>
  </div>
</div>

<style>
  /* ── Profile card ─────────────────────────────── */
  .ud-profile-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    background: #fff;
    border: 1px solid #e8edf5;
    border-radius: 1rem;
    padding: 1.5rem 1.75rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 1px 4px rgba(0,0,0,.04), 0 4px 16px rgba(0,0,0,.03);
    animation: fadeUp .4s ease both;
  }
  .ud-avatar {
    width: 72px; height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, #6366f1, #818cf8);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    position: relative;
    cursor: pointer;
    overflow: hidden;
    border: 2px solid transparent;
    transition: border-color .15s, opacity .15s;
  }
  .ud-avatar:hover { border-color: #6366f1; }
  .ud-avatar.loading { opacity: .5; pointer-events: none; }
  .ud-avatar-img {
    width: 100%; height: 100%;
    object-fit: cover; border-radius: 50%; display: block;
  }
  .ud-avatar-cam {
    position: absolute; bottom: 2px; right: 2px;
    width: 22px; height: 22px; border-radius: 50%;
    background: #e2e8f0; border: 2px solid #fff;
    display: flex; align-items: center; justify-content: center;
    color: #64748b; pointer-events: none;
  }
  .ud-profile-body { flex: 1; min-width: 0; }
  .ud-profile-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: .75rem;
  }
  .ud-profile-title { display: flex; flex-direction: column; gap: .4rem; }
  .ud-name { font-size: 1.375rem; font-weight: 700; color: #0f172a; letter-spacing: -.02em; }
  .ud-badges { display: flex; align-items: center; gap: .4rem; flex-wrap: wrap; }
  .ud-actions { display: flex; align-items: center; gap: .5rem; flex-shrink: 0; }

  /* ── Buttons ──────────────────────────────────── */
  .ud-btn {
    display: inline-flex; align-items: center; gap: .375rem;
    font-size: .8rem; font-weight: 600;
    padding: .45rem .875rem;
    border-radius: .5rem;
    border: 1.5px solid transparent;
    cursor: pointer; white-space: nowrap;
    text-decoration: none;
    background: #fff;
    transition: background .15s, border-color .15s;
  }
  .ud-btn-default { border-color: #e2e8f0; color: #374151; }
  .ud-btn-default:hover { border-color: #6366f1; color: #6366f1; background: #eef2ff; }
  .ud-btn-warn    { border-color: #fbbf24; color: #d97706; }
  .ud-btn-warn:hover { background: #fffbeb; }
  .ud-btn-success { border-color: #86efac; color: #16a34a; }
  .ud-btn-success:hover { background: #f0fdf4; }

  /* ── Two-column grid ──────────────────────────── */
  .ud-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; align-items: start; }
  .ud-card { padding: 1.5rem; }
  .ud-card-header {
    display: flex; align-items: center; gap: .5rem;
    font-size: .9rem; font-weight: 700; color: #0f172a;
    margin-bottom: 1.25rem;
  }

  /* ── Detail list ──────────────────────────────── */
  .detail-list { display: flex; flex-direction: column; }
  .detail-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: .65rem 0; border-bottom: 1px solid #f1f5f9; font-size: .875rem;
  }
  .detail-row:last-child { border-bottom: none; }
  .detail-row dt { color: #94a3b8; font-weight: 500; flex-shrink: 0; }
  .detail-row dd { color: #0f172a; font-weight: 500; text-align: right; }
  .detail-row dd.mono { font-family: 'SF Mono', 'Fira Code', monospace; }

