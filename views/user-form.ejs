<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cone — <%= isEdit ? 'Edit Staff' : 'New Staff' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/client.css">
  <link rel="stylesheet" href="/css/form.css">
</head>
<body>
<%
  const roleLabels  = { super_admin: 'Super Admin', admin: 'Admin', teller: 'Teller' };
  const isSuperAdmin = user.role === 'super_admin';
  const val = (field, fallback = '') =>
    formUser[field] !== undefined && formUser[field] !== null ? formUser[field] : fallback;
  const sel = (field, value) => String(val(field)) === String(value) ? 'selected' : '';
%>
<div class="layout">

  <!-- ── Sidebar ──────────────────────────────── -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <svg viewBox="0 0 40 40" width="26" height="26" fill="none">
        <polygon points="20,3 38,37 2,37" fill="#6366f1"/>
      </svg>
      <span class="logo-text">CONE</span>
    </div>
    <nav class="sidebar-nav">
      <a href="/dashboard" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
        Dashboard
      </a>
      <a href="/clients" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        Clients
      </a>
      <a href="/transactions" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <line x1="17" y1="7" x2="7" y2="7"/>
          <polyline points="14 4 17 7 14 10"/>
          <line x1="7" y1="17" x2="17" y2="17"/>
          <polyline points="10 14 7 17 10 20"/>
        </svg>
        Transactions
      </a>
      <a href="/requests" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
        </svg>
        Requests
      </a>
      <a href="/users" class="nav-link active">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <line x1="23" y1="11" x2="17" y2="11"/><line x1="20" y1="8" x2="20" y2="14"/>
        </svg>
        Staff
      </a>
      <a href="/logs" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
        </svg>
        Logs
      </a>
    </nav>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.name[0].toUpperCase() %></div>
      <div class="user-info">
        <div class="user-name"><%= user.name %></div>
        <span class="role-badge <%= user.role %>"><%= roleLabels[user.role] || user.role %></span>
      </div>
    </div>
  </aside>

  <!-- ── Main Content ──────────────────────────── -->
  <div class="main-content">

    <header class="topbar">
      <div class="topbar-breadcrumb">
        <a href="/dashboard" class="back-link">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          Dashboard
        </a>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" class="breadcrumb-sep">
          <path d="M9 18l6-6-6-6"/>
        </svg>
        <a href="/users" class="back-link">Staff</a>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" class="breadcrumb-sep">
          <path d="M9 18l6-6-6-6"/>
        </svg>
        <span class="breadcrumb-current"><%= isEdit ? 'Edit Account' : 'New Account' %></span>
      </div>
      <a href="/users" class="btn-cancel">Cancel</a>
    </header>

    <div class="page-content">
      <div class="form-page-wrap">

        <div class="form-page-header">
          <div class="form-page-icon">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <line x1="23" y1="11" x2="17" y2="11"/><line x1="20" y1="8" x2="20" y2="14"/>
            </svg>
          </div>
          <div>
            <h1 class="form-page-title"><%= isEdit ? 'Edit Staff Account' : 'New Staff Account' %></h1>
            <p class="form-page-sub">
              <%= isEdit
                ? 'Update account details. Leave password blank to keep the current one.'
                : 'Create a login account for a new ' + (isSuperAdmin ? 'admin or teller' : 'teller') + '.' %>
            </p>
          </div>
        </div>

        <% if (errors && errors.length) { %>
        <div class="form-errors">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" class="form-errors-icon">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><circle cx="12" cy="16" r=".5" fill="currentColor"/>
          </svg>
          <div>
            <strong>Please fix the following:</strong>
            <ul><% errors.forEach(e => { %><li><%= e %></li><% }) %></ul>
          </div>
        </div>
        <% } %>

        <form
          action="<%= isEdit ? `/users/${formUser._id}` : '/users' %>"
          method="POST"
          class="client-form"
          novalidate
        >

          <!-- Section: Account Info -->
          <div class="form-section">
            <div class="form-section-label">
              <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
              Account Details
            </div>
            <div class="form-grid">

              <div class="form-group form-col-full">
                <label for="name">Full Name <span class="req">*</span></label>
                <input type="text" id="name" name="name"
                       value="<%= val('name') %>"
                       placeholder="e.g. Jane Osei"
                       required autocomplete="off">
              </div>

              <div class="form-group form-col-full">
                <label for="email">Email Address <span class="req">*</span></label>
                <input type="email" id="email" name="email"
                       value="<%= val('email') %>"
                       placeholder="e.g. jane@bank.com"
                       required autocomplete="off">
              </div>

              <div class="form-group">
                <label for="role">Role <span class="req">*</span></label>
                <div class="select-wrap">
                  <select id="role" name="role" required>
                    <% manageableRoles.forEach(r => { %>
                    <option value="<%= r %>" <%= sel('role', r) %>><%= roleLabels[r] %></option>
                    <% }) %>
                  </select>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" class="select-chevron">
                    <path d="M6 9l6 6 6-6"/>
                  </svg>
                </div>
              </div>

            </div>
          </div>

          <!-- Section: Password -->
          <div class="form-section">
            <div class="form-section-label">
              <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
              Password
            </div>
            <div class="form-grid">

              <div class="form-group form-col-full">
                <label for="password">
                  <%= isEdit ? 'New Password' : 'Password' %>
                  <% if (!isEdit) { %><span class="req">*</span><% } %>
                </label>
                <input type="password" id="password" name="password"
                       placeholder="<%= isEdit ? 'Leave blank to keep current password' : 'Minimum 6 characters' %>"
                       autocomplete="new-password"
                       minlength="6"
                       <%= !isEdit ? 'required' : '' %>>
                <% if (isEdit) { %>
                <span class="field-hint">Only fill this in if you want to change the password.</span>
                <% } %>
              </div>

            </div>
          </div>

          <!-- Actions -->
          <div class="form-actions">
            <a href="/users" class="btn-cancel-form">Cancel</a>
            <button type="submit" class="btn-save">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                <polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/>
              </svg>
              <%= isEdit ? 'Save Changes' : 'Create Account' %>
            </button>
          </div>

        </form>
      </div>
    </div>
  </div>
</div>
</body>
</html>
