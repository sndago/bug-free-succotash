<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cone — Archive</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/client.css">
</head>
<body>
<%
  const roleLabels = { super_admin: 'Super Admin', admin: 'Admin', teller: 'Teller' };
  const fmtDate    = d => new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  const fmtMoney   = n => '$' + Number(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const urgencyClass = days => days <= 7 ? 'days-critical' : days <= 14 ? 'days-warning' : 'days-safe';
%>
<div class="layout">

  <!-- ── Sidebar ──────────────────────────────── -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <svg viewBox="0 0 40 40" width="26" height="26" fill="none">
        <polygon points="20,3 38,37 2,37" fill="#6366f1"/>
      </svg>
      <span class="logo-text">CONE</span>
    </div>
    <nav class="sidebar-nav">
      <a href="/dashboard" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
        Dashboard
      </a>
      <a href="/clients" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        Clients
      </a>
      <a href="/transactions" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <line x1="17" y1="7" x2="7" y2="7"/>
          <polyline points="14 4 17 7 14 10"/>
          <line x1="7" y1="17" x2="17" y2="17"/>
          <polyline points="10 14 7 17 10 20"/>
        </svg>
        Transactions
      </a>
      <a href="/requests" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
        </svg>
        Requests
      </a>
      <a href="/users" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <line x1="23" y1="11" x2="17" y2="11"/><line x1="20" y1="8" x2="20" y2="14"/>
        </svg>
        Staff
      </a>
      <a href="/logs" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
        </svg>
        Logs
      </a>
      <a href="/branches" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        Branches
      </a>
      <a href="/archive" class="nav-link active">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <polyline points="21 8 21 21 3 21 3 8"/>
          <rect x="1" y="3" width="22" height="5"/>
          <line x1="10" y1="12" x2="14" y2="12"/>
        </svg>
        Archive
      </a>
    </nav>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.name[0].toUpperCase() %></div>
      <div class="user-info">
        <div class="user-name"><%= user.name %></div>
        <span class="role-badge <%= user.role %>"><%= roleLabels[user.role] || user.role %></span>
      </div>
    </div>
  </aside>

  <!-- ── Main Content ──────────────────────────── -->
  <div class="main-content">
    <header class="topbar">
      <div class="topbar-breadcrumb">
        <a href="/dashboard" class="back-link">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          Dashboard
        </a>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" class="breadcrumb-sep">
          <path d="M9 18l6-6-6-6"/>
        </svg>
        <span class="breadcrumb-current">Archive</span>
      </div>
      <form action="/logout" method="POST">
        <button type="submit" class="btn-logout">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
          Sign out
        </button>
      </form>
    </header>

    <div class="page-content">

      <% if (locals.flash) { %>
      <div class="flash flash-<%= flash.type %>">
        <% if (flash.type === 'success') { %>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <% } else { %>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><circle cx="12" cy="16" r=".5" fill="currentColor"/></svg>
        <% } %>
        <%= flash.message %>
      </div>
      <% } %>

      <div class="archive-notice">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><circle cx="12" cy="16" r=".5" fill="currentColor"/>
        </svg>
        Archived records are kept for <strong>60 days</strong> before being permanently deleted. Restore a record at any time before its expiry.
      </div>

      <!-- ── Archived Clients ──────────────────── -->
      <div class="table-card" style="margin-bottom:1.5rem">
        <div class="table-header">
          <h3>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" style="vertical-align:middle;margin-right:.4rem">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
            Archived Clients
            <span class="archive-count"><%= clients.length %></span>
          </h3>
        </div>
        <% if (!clients.length) { %>
        <div class="empty-state" style="padding:2rem">
          <p style="color:#94a3b8;font-size:.875rem">No archived clients.</p>
        </div>
        <% } else { %>
        <div class="table-wrapper">
          <table class="clients-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Account #</th>
                <th>Type</th>
                <th>Balance</th>
                <th>Deleted</th>
                <th>Deleted By</th>
                <th>Expires In</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% clients.forEach(c => { %>
              <tr>
                <td><div class="client-name"><%= c.name %></div></td>
                <td><span class="txn-desc"><%= c.accountNumber %></span></td>
                <td><span class="txn-desc" style="text-transform:capitalize"><%= c.accountType %></span></td>
                <td><span class="txn-desc"><%= fmtMoney(c.balance) %></span></td>
                <td class="date-cell"><div class="txn-date"><%= fmtDate(c.deletedAt) %></div></td>
                <td><span class="txn-desc"><%= c.deletedBy?.name || '—' %></span></td>
                <td>
                  <span class="days-badge <%= urgencyClass(c.daysRemaining) %>">
                    <%= c.daysRemaining %> day<%= c.daysRemaining !== 1 ? 's' : '' %>
                  </span>
                </td>
                <td class="txn-actions-cell">
                  <form action="/archive/clients/<%= c._id %>/restore" method="POST" style="display:inline"
                        data-confirm="Restore <%= c.name %>'s account? It will become active again."
                        data-confirm-title="Restore Client"
                        data-confirm-ok="Restore">
                    <button type="submit" class="btn-restore" title="Restore">
                      <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.48"/>
                      </svg>
                      Restore
                    </button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

      <!-- ── Archived Transactions ─────────────── -->
      <div class="table-card" style="margin-bottom:1.5rem">
        <div class="table-header">
          <h3>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" style="vertical-align:middle;margin-right:.4rem">
              <line x1="17" y1="7" x2="7" y2="7"/><polyline points="14 4 17 7 14 10"/>
              <line x1="7" y1="17" x2="17" y2="17"/><polyline points="10 14 7 17 10 20"/>
            </svg>
            Archived Transactions
            <span class="archive-count"><%= transactions.length %></span>
          </h3>
        </div>
        <% if (!transactions.length) { %>
        <div class="empty-state" style="padding:2rem">
          <p style="color:#94a3b8;font-size:.875rem">No archived transactions.</p>
        </div>
        <% } else { %>
        <div class="table-wrapper">
          <table class="clients-table">
            <thead>
              <tr>
                <th>Client</th>
                <th>Type</th>
                <th>Category</th>
                <th>Amount</th>
                <th>Deleted</th>
                <th>Deleted By</th>
                <th>Expires In</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% transactions.forEach(t => { %>
              <tr>
                <td>
                  <div class="client-name"><%= t.client?.name || 'Unknown' %></div>
                  <div class="txn-desc" style="font-size:.75rem;color:#94a3b8"><%= t.client?.accountNumber || '' %></div>
                </td>
                <td>
                  <span class="approval-badge <%= t.type === 'credit' ? 'approval-approved' : 'approval-rejected' %>">
                    <%= t.type %>
                  </span>
                </td>
                <td><span class="txn-desc" style="text-transform:capitalize"><%= t.category %></span></td>
                <td><strong><%= fmtMoney(t.amount) %></strong></td>
                <td class="date-cell"><div class="txn-date"><%= fmtDate(t.deletedAt) %></div></td>
                <td><span class="txn-desc"><%= t.deletedBy?.name || '—' %></span></td>
                <td>
                  <span class="days-badge <%= urgencyClass(t.daysRemaining) %>">
                    <%= t.daysRemaining %> day<%= t.daysRemaining !== 1 ? 's' : '' %>
                  </span>
                </td>
                <td class="txn-actions-cell">
                  <% if (t.client) { %>
                  <form action="/archive/transactions/<%= t._id %>/restore" method="POST" style="display:inline"
                        data-confirm="Restore this <%= t.category %> of <%= fmtMoney(t.amount) %>? The client balance will be re-applied."
                        data-confirm-title="Restore Transaction"
                        data-confirm-ok="Restore">
                    <button type="submit" class="btn-restore" title="Restore">
                      <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.48"/>
                      </svg>
                      Restore
                    </button>
                  </form>
                  <% } else { %>
                  <span style="font-size:.75rem;color:#94a3b8">Client deleted</span>
                  <% } %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

      <!-- ── Archived Users ────────────────────── -->
      <div class="table-card">
        <div class="table-header">
          <h3>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" style="vertical-align:middle;margin-right:.4rem">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
              <line x1="23" y1="11" x2="17" y2="11"/><line x1="20" y1="8" x2="20" y2="14"/>
            </svg>
            Archived Staff
            <span class="archive-count"><%= users.length %></span>
          </h3>
        </div>
        <% if (!users.length) { %>
        <div class="empty-state" style="padding:2rem">
          <p style="color:#94a3b8;font-size:.875rem">No archived staff accounts.</p>
        </div>
        <% } else { %>
        <div class="table-wrapper">
          <table class="clients-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Deleted</th>
                <th>Deleted By</th>
                <th>Expires In</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(u => { %>
              <tr>
                <td><div class="client-name"><%= u.name %></div></td>
                <td><span class="txn-desc"><%= u.email %></span></td>
                <td>
                  <span class="role-badge <%= u.role %>" style="font-size:.75rem">
                    <%= roleLabels[u.role] || u.role %>
                  </span>
                </td>
                <td class="date-cell"><div class="txn-date"><%= fmtDate(u.deletedAt) %></div></td>
                <td><span class="txn-desc"><%= u.deletedBy?.name || '—' %></span></td>
                <td>
                  <span class="days-badge <%= urgencyClass(u.daysRemaining) %>">
                    <%= u.daysRemaining %> day<%= u.daysRemaining !== 1 ? 's' : '' %>
                  </span>
                </td>
                <td class="txn-actions-cell">
                  <form action="/archive/users/<%= u._id %>/restore" method="POST" style="display:inline"
                        data-confirm="Restore <%= u.name %>? They will be reactivated and can log in again."
                        data-confirm-title="Restore Staff Account"
                        data-confirm-ok="Restore">
                    <button type="submit" class="btn-restore" title="Restore">
                      <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.48"/>
                      </svg>
                      Restore
                    </button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

    </div>
  </div>
</div>

<style>
  .archive-notice {
    display: flex;
    align-items: center;
    gap: .5rem;
    background: #1e293b;
    border: 1px solid #334155;
    border-left: 3px solid #6366f1;
    border-radius: 8px;
    padding: .75rem 1rem;
    font-size: .85rem;
    color: #cbd5e1;
    margin-bottom: 1.25rem;
  }
  .archive-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #334155;
    color: #94a3b8;
    font-size: .7rem;
    font-weight: 600;
    border-radius: 999px;
    padding: 0 .5rem;
    height: 1.25rem;
    margin-left: .5rem;
    vertical-align: middle;
  }
  .days-badge {
    display: inline-block;
    font-size: .75rem;
    font-weight: 600;
    padding: .2rem .6rem;
    border-radius: 999px;
  }
  .days-safe     { background: #14532d22; color: #4ade80; border: 1px solid #166534; }
  .days-warning  { background: #78350f22; color: #fbbf24; border: 1px solid #92400e; }
  .days-critical { background: #7f1d1d22; color: #f87171; border: 1px solid #991b1b; }
  .btn-restore {
    display: inline-flex;
    align-items: center;
    gap: .3rem;
    background: transparent;
    border: 1px solid #6366f1;
    color: #818cf8;
    border-radius: 6px;
    padding: .3rem .65rem;
    font-size: .75rem;
    font-weight: 500;
    cursor: pointer;
    transition: background .15s, color .15s;
  }
  .btn-restore:hover { background: #6366f120; color: #a5b4fc; }
</style>

<!-- ── Mobile: backdrop + drawer toggle ─────────────── -->
<div class="sidebar-backdrop" id="sidebarBackdrop" onclick="closeSidebar()"></div>

<!-- ── Mobile: bottom navigation bar ───────────────── -->
<nav class="mobile-nav">
  <a href="/dashboard" class="mobile-nav-item" data-path="/dashboard">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75">
      <rect x="3" y="3" width="7" height="7" rx="1"/>
      <rect x="14" y="3" width="7" height="7" rx="1"/>
      <rect x="3" y="14" width="7" height="7" rx="1"/>
      <rect x="14" y="14" width="7" height="7" rx="1"/>
    </svg>
    Home
  </a>
  <a href="/clients" class="mobile-nav-item" data-path="/clients">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75">
      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
      <circle cx="9" cy="7" r="4"/>
    </svg>
    Clients
  </a>
  <a href="/transactions" class="mobile-nav-item" data-path="/transactions">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75">
      <line x1="17" y1="7" x2="7" y2="7"/>
      <polyline points="14 4 17 7 14 10"/>
      <line x1="7" y1="17" x2="17" y2="17"/>
      <polyline points="10 14 7 17 10 20"/>
    </svg>
    Txns
  </a>
  <button class="mobile-nav-item" onclick="openSidebar()">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75">
      <line x1="3" y1="6" x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
    Menu
  </button>
</nav>

<script>
  (function () {
    var path = window.location.pathname;
    document.querySelectorAll('.mobile-nav-item[data-path]').forEach(function (item) {
      if (path === item.dataset.path || path.startsWith(item.dataset.path + '/')) {
        item.classList.add('active');
      }
    });
  })();

  function openSidebar() {
    document.getElementById('sidebar').classList.add('open');
    document.getElementById('sidebarBackdrop').classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeSidebar() {
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sidebarBackdrop').classList.remove('open');
    document.body.style.overflow = '';
  }
</script>

<script src="/js/modal.js"></script>
</body>
</html>
