<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cone — Transactions</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/client.css">
  <style>
    .filter-bar {
      display: flex; flex-wrap: wrap; gap: .75rem; align-items: flex-end;
      background: #f8fafc; border: 1px solid #e2e8f0; border-radius: .75rem;
      padding: 1rem 1.25rem; margin-bottom: 1.25rem;
    }
    .filter-bar label { display:block; font-size:.75rem; font-weight:600; color:#64748b; margin-bottom:.3rem; }
    .filter-bar select {
      height: 2.1rem; padding: 0 .625rem; border: 1.5px solid #e2e8f0; border-radius: .5rem;
      font-size: .8rem; color: #0f172a; background: #fff; font-family: inherit; min-width: 140px;
    }
    .filter-bar select:focus { outline: none; border-color: #6366f1; }
    .filter-bar .filter-field { display:flex; flex-direction:column; }
    .btn-filter {
      height: 2.1rem; padding: 0 1rem; background: #6366f1; color: #fff;
      border: none; border-radius: .5rem; font-size: .8rem; font-weight: 600;
      cursor: pointer; font-family: inherit; align-self: flex-end;
    }
    .btn-filter:hover { background: #4f46e5; }
    .btn-clear {
      height: 2.1rem; padding: 0 .875rem; background: transparent; color: #64748b;
      border: 1.5px solid #e2e8f0; border-radius: .5rem; font-size: .8rem; font-weight: 500;
      cursor: pointer; font-family: inherit; text-decoration: none;
      display: inline-flex; align-items: center; align-self: flex-end;
    }
    .btn-clear:hover { border-color: #94a3b8; color: #334155; }
  </style>
</head>
<body>
<%
  const roleLabels = { super_admin: 'Super Admin', admin: 'Admin', teller: 'Teller' };
  const fmt     = n => Number(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const fmtDate = d => new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  const fmtTime = d => new Date(d).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
%>
<div class="layout">

  <!-- ── Sidebar ──────────────────────────────── -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <svg viewBox="0 0 40 40" width="26" height="26" fill="none">
        <polygon points="20,3 38,37 2,37" fill="#6366f1"/>
      </svg>
      <span class="logo-text">CONE</span>
    </div>
    <nav class="sidebar-nav">
      <a href="/dashboard" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
        Dashboard
      </a>
      <a href="/clients" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        Clients
      </a>
      <a href="/transactions" class="nav-link active">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <line x1="17" y1="7" x2="7" y2="7"/>
          <polyline points="14 4 17 7 14 10"/>
          <line x1="7" y1="17" x2="17" y2="17"/>
          <polyline points="10 14 7 17 10 20"/>
        </svg>
        Transactions
      </a>
      <% if (['admin','super_admin'].includes(user.role)) { %>
      <a href="/requests" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
        </svg>
        Requests
      </a>
      <a href="/users" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <line x1="23" y1="11" x2="17" y2="11"/><line x1="20" y1="8" x2="20" y2="14"/>
        </svg>
        Staff
      </a>
      <a href="/logs" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
        </svg>
        Logs
      </a>
      <% } %>
    </nav>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.name[0].toUpperCase() %></div>
      <div class="user-info">
        <div class="user-name"><%= user.name %></div>
        <span class="role-badge <%= user.role %>"><%= roleLabels[user.role] || user.role %></span>
      </div>
    </div>
  </aside>

  <!-- ── Main Content ──────────────────────────── -->
  <div class="main-content">
    <header class="topbar">
      <div class="topbar-breadcrumb">
        <a href="/dashboard" class="back-link">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          Dashboard
        </a>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" class="breadcrumb-sep">
          <path d="M9 18l6-6-6-6"/>
        </svg>
        <span class="breadcrumb-current">Transactions</span>
      </div>
      <form action="/logout" method="POST">
        <button type="submit" class="btn-logout">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
          Sign out
        </button>
      </form>
    </header>

    <div class="page-content">

      <% if (locals.flash) { %>
      <div class="flash flash-<%= flash.type %>">
        <% if (flash.type === 'success') { %>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <% } else { %>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><circle cx="12" cy="16" r=".5" fill="currentColor"/></svg>
        <% } %>
        <%= flash.message %>
      </div>
      <% } %>

      <!-- Filter bar -->
      <form method="GET" action="/transactions" class="filter-bar">
        <div class="filter-field">
          <label>Type</label>
          <select name="type">
            <option value="">All Types</option>
            <option value="credit" <%= filters.type === 'credit' ? 'selected' : '' %>>Credit</option>
            <option value="debit"  <%= filters.type === 'debit'  ? 'selected' : '' %>>Debit</option>
          </select>
        </div>
        <div class="filter-field">
          <label>Category</label>
          <select name="category">
            <option value="">All Categories</option>
            <% CATEGORIES.forEach(cat => { %>
            <option value="<%= cat %>" <%= filters.category === cat ? 'selected' : '' %>><%= cat.charAt(0).toUpperCase() + cat.slice(1) %></option>
            <% }) %>
          </select>
        </div>
        <div class="filter-field">
          <label>Status</label>
          <select name="status">
            <option value="">All Statuses</option>
            <option value="completed" <%= filters.status === 'completed' ? 'selected' : '' %>>Completed</option>
            <option value="pending"   <%= filters.status === 'pending'   ? 'selected' : '' %>>Pending</option>
            <option value="failed"    <%= filters.status === 'failed'    ? 'selected' : '' %>>Failed</option>
          </select>
        </div>
        <button type="submit" class="btn-filter">Filter</button>
        <% if (filters.type || filters.category || filters.status) { %>
        <a href="/transactions" class="btn-clear">Clear</a>
        <% } %>
      </form>

      <div class="table-card">
        <div class="table-header">
          <h3>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" style="vertical-align:middle;margin-right:.4rem">
              <line x1="17" y1="7" x2="7" y2="7"/>
              <polyline points="14 4 17 7 14 10"/>
              <line x1="7" y1="17" x2="17" y2="17"/>
              <polyline points="10 14 7 17 10 20"/>
            </svg>
            All Transactions
          </h3>
        </div>

        <% if (!transactions || transactions.length === 0) { %>
        <div class="empty-state">
          <svg viewBox="0 0 24 24" width="56" height="56" fill="none" stroke="currentColor" stroke-width="1">
            <line x1="17" y1="7" x2="7" y2="7"/>
            <polyline points="14 4 17 7 14 10"/>
            <line x1="7" y1="17" x2="17" y2="17"/>
            <polyline points="10 14 7 17 10 20"/>
          </svg>
          <p>No transactions found.</p>
        </div>
        <% } else { %>
        <div class="table-wrapper">
          <table class="clients-table txn-table">
            <thead>
              <tr>
                <th>Date</th>
                <th>Client</th>
                <th>Description</th>
                <th>Category</th>
                <th>Type</th>
                <th class="col-right">Amount</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% transactions.forEach(txn => { %>
              <tr onclick="window.location='/clients/<%= txn.client._id %>'" style="cursor:pointer">
                <td class="date-cell">
                  <div class="txn-date"><%= fmtDate(txn.date) %></div>
                  <div class="txn-time"><%= fmtTime(txn.date) %></div>
                </td>
                <td>
                  <div class="client-name"><%= txn.client.name %></div>
                  <div class="txn-time"><code><%= txn.client.accountNumber %></code></div>
                </td>
                <td><span class="txn-desc"><%= txn.description %></span></td>
                <td><span class="cat-badge cat-<%= txn.category %>"><%= txn.category %></span></td>
                <td><span class="txn-status txn-status-<%= txn.type %>"><%= txn.type %></span></td>
                <td class="col-right">
                  <% if (txn.type === 'credit') { %>
                  <span class="amount-credit">+$<%= fmt(txn.amount) %></span>
                  <% } else { %>
                  <span class="amount-debit">−$<%= fmt(txn.amount) %></span>
                  <% } %>
                </td>
                <td>
                  <% if (txn.requiresApproval && txn.approvalStatus !== 'na') { %>
                  <span class="approval-badge approval-<%= txn.approvalStatus %>">
                    <% if (txn.approvalStatus === 'approved') { %>
                    <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    Approved
                    <% } else if (txn.approvalStatus === 'rejected') { %>
                    <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Rejected
                    <% } else { %>
                    Pending
                    <% } %>
                  </span>
                  <% } else { %>
                  <span class="txn-status-badge <%= txn.status %>"><%= txn.status %></span>
                  <% } %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <div class="table-footer-bar">
          <span class="txn-count-label"><strong><%= transactions.length %></strong> transaction<%= transactions.length !== 1 ? 's' : '' %><%= transactions.length === 200 ? ' (showing latest 200)' : '' %></span>
        </div>
        <% } %>
      </div>

    </div><!-- /page-content -->
  </div><!-- /main-content -->
</div><!-- /layout -->
</body>
</html>
