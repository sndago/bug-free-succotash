<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cone — Staff</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/client.css">
</head>
<body>
<%
  const roleLabels = { super_admin: 'Super Admin', admin: 'Admin', teller: 'Teller' };
  const fmtDate    = d => new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  const isSuperAdmin = user.role === 'super_admin';
%>
<div class="layout">

  <!-- ── Sidebar ──────────────────────────────── -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <svg viewBox="0 0 40 40" width="26" height="26" fill="none">
        <polygon points="20,3 38,37 2,37" fill="#6366f1"/>
      </svg>
      <span class="logo-text">CONE</span>
    </div>
    <nav class="sidebar-nav">
      <a href="/dashboard" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
        Dashboard
      </a>
      <a href="/clients" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        Clients
      </a>
      <a href="/transactions" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <line x1="17" y1="7" x2="7" y2="7"/>
          <polyline points="14 4 17 7 14 10"/>
          <line x1="7" y1="17" x2="17" y2="17"/>
          <polyline points="10 14 7 17 10 20"/>
        </svg>
        Transactions
      </a>
      <a href="/requests" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
        </svg>
        Requests
      </a>
      <a href="/users" class="nav-link active">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <line x1="23" y1="11" x2="17" y2="11"/><line x1="20" y1="8" x2="20" y2="14"/>
        </svg>
        Staff
      </a>
      <a href="/logs" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
        </svg>
        Logs
      </a>
      <% if (user.role === 'super_admin') { %>
      <a href="/archive" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <polyline points="21 8 21 21 3 21 3 8"/>
          <rect x="1" y="3" width="22" height="5"/>
          <line x1="10" y1="12" x2="14" y2="12"/>
        </svg>
        Archive
      </a>
      <% } %>
    </nav>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.name[0].toUpperCase() %></div>
      <div class="user-info">
        <div class="user-name"><%= user.name %></div>
        <span class="role-badge <%= user.role %>"><%= roleLabels[user.role] || user.role %></span>
      </div>
    </div>
  </aside>

  <!-- ── Main Content ──────────────────────────── -->
  <div class="main-content">
    <header class="topbar">
      <div class="topbar-breadcrumb">
        <a href="/dashboard" class="back-link">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          Dashboard
        </a>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" class="breadcrumb-sep">
          <path d="M9 18l6-6-6-6"/>
        </svg>
        <span class="breadcrumb-current">Staff</span>
      </div>
      <div style="display:flex;gap:.75rem;align-items:center">
        <a href="/users/new" class="btn-new-client">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
          New <%= isSuperAdmin ? 'Staff' : 'Teller' %>
        </a>
        <form action="/logout" method="POST">
          <button type="submit" class="btn-logout">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
              <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            Sign out
          </button>
        </form>
      </div>
    </header>

    <div class="page-content">

      <% if (flash) { %>
      <div class="flash flash-<%= flash.type %>">
        <% if (flash.type === 'success') { %>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <% } else { %>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><circle cx="12" cy="16" r=".5" fill="currentColor"/></svg>
        <% } %>
        <%= flash.message %>
      </div>
      <% } %>

      <div class="table-card">
        <div class="table-header">
          <div class="txn-header-left">
            <h3>
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" style="vertical-align:middle;margin-right:.4rem">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <line x1="23" y1="11" x2="17" y2="11"/><line x1="20" y1="8" x2="20" y2="14"/>
              </svg>
              Staff Accounts
            </h3>
          </div>
          <div class="table-header-right">
            <input type="text" class="search-input" placeholder="Search staff…" oninput="filterUsers(this.value)">
          </div>
        </div>

        <% if (!users || users.length === 0) { %>
        <div class="empty-state">
          <svg viewBox="0 0 24 24" width="56" height="56" fill="none" stroke="currentColor" stroke-width="1">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <line x1="23" y1="11" x2="17" y2="11"/><line x1="20" y1="8" x2="20" y2="14"/>
          </svg>
          <p>No staff accounts yet. <a href="/users/new" class="link-inline">Create one.</a></p>
        </div>
        <% } else { %>
        <div class="table-wrapper">
          <table class="clients-table" id="usersTable">
            <thead>
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Clients</th>
                <th>Status</th>
                <th>Created</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(u => { %>
              <tr class="<%= u.isActive ? '' : 'row-inactive' %>">
                <td>
                  <div class="client-name"><%= u.name %></div>
                </td>
                <td>
                  <span class="txn-desc"><%= u.email %></span>
                </td>
                <td>
                  <span class="role-badge <%= u.role %>" style="font-size:.75rem">
                    <%= roleLabels[u.role] || u.role %>
                  </span>
                </td>
                <td>
                  <% if (u.role === 'teller') { %>
                  <span class="txn-count-label"><%= u.clientCount %> client<%= u.clientCount !== 1 ? 's' : '' %></span>
                  <% } else { %>
                  <span style="color:#94a3b8;font-size:.8rem">—</span>
                  <% } %>
                </td>
                <td>
                  <% if (u.isActive) { %>
                  <span class="approval-badge approval-approved">
                    <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    Active
                  </span>
                  <% } else { %>
                  <span class="approval-badge approval-rejected">
                    <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Inactive
                  </span>
                  <% } %>
                </td>
                <td class="date-cell">
                  <div class="txn-date"><%= fmtDate(u.createdAt) %></div>
                </td>
                <td class="txn-actions-cell">
                  <div class="txn-row-actions">
                    <a href="/users/<%= u._id %>/edit" class="btn-txn-edit" title="Edit">
                      <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                      </svg>
                    </a>
                    <form action="/users/<%= u._id %>/toggle" method="POST" style="display:inline"
                          data-confirm="<%= u.isActive ? 'Deactivate' : 'Reactivate' %> <%= u.name %>?"
                          data-confirm-title="<%= u.isActive ? 'Deactivate' : 'Reactivate' %> Staff"
                          data-confirm-variant="<%= u.isActive ? 'warning' : 'primary' %>"
                          data-confirm-ok="<%= u.isActive ? 'Deactivate' : 'Reactivate' %>">
                      <button type="submit"
                              class="btn-txn-edit"
                              title="<%= u.isActive ? 'Deactivate' : 'Reactivate' %>"
                              style="<%= u.isActive ? 'border-color:#fbbf24;color:#d97706' : 'border-color:#86efac;color:#16a34a' %>">
                        <% if (u.isActive) { %>
                        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2">
                          <circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
                        </svg>
                        <% } else { %>
                        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2">
                          <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        <% } %>
                      </button>
                    </form>
                    <% if (isSuperAdmin) { %>
                    <form action="/users/<%= u._id %>/delete" method="POST" style="display:inline"
                          data-confirm="Archive <%= u.name %>'s account? Their assigned clients will be unassigned and the account will be permanently deleted after 60 days."
                          data-confirm-title="Archive Staff Account"
                          data-confirm-danger
                          data-confirm-ok="Yes, archive">
                      <button type="submit" class="btn-txn-delete" title="Delete">
                        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2">
                          <polyline points="3 6 5 6 21 6"/>
                          <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                          <path d="M10 11v6"/><path d="M14 11v6"/>
                        </svg>
                      </button>
                    </form>
                    <% } %>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <div class="table-footer-bar">
          <span class="txn-count-label">
            <strong><%= users.length %></strong> staff member<%= users.length !== 1 ? 's' : '' %>
          </span>
        </div>
        <% } %>
      </div>

    </div>
  </div>
</div>

<style>
  .row-inactive td { opacity: .5; }
  .link-inline { color: #6366f1; text-decoration: none; font-weight: 600; }
  .link-inline:hover { text-decoration: underline; }
</style>

<script>
  function filterUsers(q) {
    const term = q.toLowerCase();
    document.querySelectorAll('#usersTable tbody tr').forEach(row => {
      row.style.display = row.textContent.toLowerCase().includes(term) ? '' : 'none';
    });
  }
</script>
<!-- ── Mobile: backdrop + drawer toggle ─────────────── -->
<div class="sidebar-backdrop" id="sidebarBackdrop" onclick="closeSidebar()"></div>

<!-- ── Mobile: bottom navigation bar ───────────────── -->
<nav class="mobile-nav">
  <a href="/dashboard" class="mobile-nav-item" data-path="/dashboard">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75">
      <rect x="3" y="3" width="7" height="7" rx="1"/>
      <rect x="14" y="3" width="7" height="7" rx="1"/>
      <rect x="3" y="14" width="7" height="7" rx="1"/>
      <rect x="14" y="14" width="7" height="7" rx="1"/>
    </svg>
    Home
  </a>
  <a href="/clients" class="mobile-nav-item" data-path="/clients">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75">
      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
      <circle cx="9" cy="7" r="4"/>
    </svg>
    Clients
  </a>
  <a href="/transactions" class="mobile-nav-item" data-path="/transactions">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75">
      <line x1="17" y1="7" x2="7" y2="7"/>
      <polyline points="14 4 17 7 14 10"/>
      <line x1="7" y1="17" x2="17" y2="17"/>
      <polyline points="10 14 7 17 10 20"/>
    </svg>
    Txns
  </a>
  <button class="mobile-nav-item" onclick="openSidebar()">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75">
      <line x1="3" y1="6" x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
    Menu
  </button>
</nav>

<script>
  // Mark active bottom nav item by current URL path
  (function () {
    var path = window.location.pathname;
    document.querySelectorAll('.mobile-nav-item[data-path]').forEach(function (item) {
      if (path === item.dataset.path || path.startsWith(item.dataset.path + '/')) {
        item.classList.add('active');
      }
    });
  })();

  function openSidebar() {
    document.getElementById('sidebar').classList.add('open');
    document.getElementById('sidebarBackdrop').classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeSidebar() {
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sidebarBackdrop').classList.remove('open');
    document.body.style.overflow = '';
  }
</script>

<script src="/js/modal.js"></script>
</body>
</html>
