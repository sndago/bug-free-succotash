<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cone — Balance by Branch</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/client.css">
</head>
<body>
<%
  const roleLabels  = { super_admin: 'Super Admin', admin: 'Admin', teller: 'Teller' };
  const isSuperAdmin = user.role === 'super_admin';
  const fmt  = n => Number(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const fmtK = n => {
    n = Number(n);
    if (n >= 1000000) return '₵' + (n / 1000000).toFixed(2) + 'M';
    if (n >= 1000)    return '₵' + (n / 1000).toFixed(1) + 'K';
    return '₵' + fmt(n);
  };
  const totalClients = rows.reduce((s, r) => s + r.clientCount, 0);
  const branchCount  = rows.filter(r => r.branch).length;
%>
<div class="layout">

  <!-- ── Sidebar ──────────────────────────────── -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <svg viewBox="0 0 40 40" width="26" height="26" fill="none">
        <polygon points="20,3 38,37 2,37" fill="#6366f1"/>
      </svg>
      <span class="logo-text">CONE</span>
    </div>
    <nav class="sidebar-nav">
      <a href="/dashboard" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
        Dashboard
      </a>
      <a href="/clients" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        Clients
      </a>
      <a href="/transactions" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <line x1="17" y1="7" x2="7" y2="7"/>
          <polyline points="14 4 17 7 14 10"/>
          <line x1="7" y1="17" x2="17" y2="17"/>
          <polyline points="10 14 7 17 10 20"/>
        </svg>
        Transactions
      </a>
      <a href="/requests" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
        </svg>
        Requests
      </a>
      <a href="/users" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <line x1="23" y1="11" x2="17" y2="11"/><line x1="20" y1="8" x2="20" y2="14"/>
        </svg>
        Staff
      </a>
      <a href="/branches" class="nav-link active">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        Branches
      </a>
      <a href="/logs" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
        </svg>
        Logs
      </a>
      <% if (isSuperAdmin) { %>
      <a href="/archive" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <polyline points="21 8 21 21 3 21 3 8"/>
          <rect x="1" y="3" width="22" height="5"/>
          <line x1="10" y1="12" x2="14" y2="12"/>
        </svg>
        Archive
      </a>
      <% } %>
    </nav>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.name[0].toUpperCase() %></div>
      <div class="user-info">
        <div class="user-name"><%= user.name %></div>
        <span class="role-badge <%= user.role %>"><%= roleLabels[user.role] || user.role %></span>
      </div>
    </div>
  </aside>

  <!-- ── Main Content ──────────────────────────── -->
  <div class="main-content">
    <header class="topbar">
      <div class="topbar-breadcrumb">
        <a href="/dashboard" class="back-link">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          Dashboard
        </a>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" class="breadcrumb-sep">
          <path d="M9 18l6-6-6-6"/>
        </svg>
        <a href="/branches" class="back-link">Branches</a>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" class="breadcrumb-sep">
          <path d="M9 18l6-6-6-6"/>
        </svg>
        <span class="breadcrumb-current">Balance Breakdown</span>
      </div>
      <form action="/logout" method="POST">
        <button type="submit" class="btn-logout">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
          Sign out
        </button>
      </form>
    </header>

    <div class="page-content">

      <!-- ── Summary KPI strip ── -->
      <div class="stats-grid" style="margin-bottom:1.5rem">
        <div class="stat-card">
          <div class="stat-icon indigo">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5">
              <line x1="12" y1="1" x2="12" y2="23"/>
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
          </div>
          <div>
            <div class="stat-value">₵<%= fmt(grandTotal) %></div>
            <div class="stat-label">Grand Total Balance</div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon green">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </div>
          <div>
            <div class="stat-value"><%= branchCount %></div>
            <div class="stat-label">Branches with Clients</div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon blue">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
            </svg>
          </div>
          <div>
            <div class="stat-value"><%= totalClients %></div>
            <div class="stat-label">Total Clients</div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon purple">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5">
              <line x1="18" y1="20" x2="18" y2="10"/>
              <line x1="12" y1="20" x2="12" y2="4"/>
              <line x1="6"  y1="20" x2="6"  y2="14"/>
            </svg>
          </div>
          <div>
            <div class="stat-value">₵<%= totalClients > 0 ? fmt(grandTotal / totalClients) : '0.00' %></div>
            <div class="stat-label">Avg Balance / Client</div>
          </div>
        </div>
      </div>

      <!-- ── Branch balance table ── -->
      <div class="table-card">
        <div class="table-header">
          <div>
            <h3>Balance by Branch</h3>
            <span style="font-size:.8rem;color:#94a3b8;margin-top:.2rem;display:block">
              Sorted by total balance — highest first
            </span>
          </div>
          <a href="/branches" class="btn-add-client" style="white-space:nowrap">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            Manage Branches
          </a>
        </div>

        <% if (!rows.length) { %>
        <div class="empty-state" style="padding:3.5rem 2rem">
          <svg viewBox="0 0 24 24" width="52" height="52" fill="none" stroke="currentColor" stroke-width="1">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          <p>No client data yet.</p>
        </div>
        <% } else { %>
        <div class="table-wrapper">
          <table class="clients-table">
            <thead>
              <tr>
                <th style="width:2rem">#</th>
                <th>Branch</th>
                <th class="col-right">Clients</th>
                <th class="col-right">Active</th>
                <th class="col-right">Total Balance</th>
                <th class="col-right">Avg / Client</th>
                <th style="min-width:140px">Share</th>
              </tr>
            </thead>
            <tbody>
              <% rows.forEach((row, i) => {
                   const name    = row.branch ? row.branch.name : 'Unassigned';
                   const code    = row.branch ? row.branch.code : null;
                   const pct     = grandTotal > 0 ? (row.totalBalance / grandTotal) * 100 : 0;
                   const avg     = row.clientCount > 0 ? row.totalBalance / row.clientCount : 0;
                   const isUnassigned = !row.branch;
              %>
              <tr>
                <td style="color:#94a3b8;font-size:.8rem;font-weight:600"><%= i + 1 %></td>
                <td>
                  <div style="display:flex;align-items:center;gap:.625rem">
                    <div style="width:32px;height:32px;border-radius:8px;background:<%= isUnassigned ? '#f1f5f9' : '#eef2ff' %>;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                      <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="<%= isUnassigned ? '#94a3b8' : '#6366f1' %>" stroke-width="1.75">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                        <polyline points="9 22 9 12 15 12 15 22"/>
                      </svg>
                    </div>
                    <div>
                      <div style="font-weight:600;color:<%= isUnassigned ? '#94a3b8' : '#0f172a' %>;font-size:.9rem"><%= name %></div>
                      <% if (code) { %><div style="font-size:.75rem;font-family:monospace;color:#94a3b8"><%= code %></div><% } %>
                    </div>
                  </div>
                </td>
                <td class="col-right" style="font-weight:600;color:#374151"><%= row.clientCount %></td>
                <td class="col-right">
                  <span style="color:#059669;font-weight:600"><%= row.activeCount %></span>
                  <% if (row.clientCount - row.activeCount > 0) { %>
                  <span style="color:#94a3b8;font-size:.8rem"> / <%= row.clientCount - row.activeCount %> inactive</span>
                  <% } %>
                </td>
                <td class="col-right">
                  <div style="font-weight:700;color:#0f172a;font-size:.95rem">₵<%= fmt(row.totalBalance) %></div>
                  <div style="font-size:.75rem;color:#94a3b8"><%= fmtK(row.totalBalance) %></div>
                </td>
                <td class="col-right" style="color:#64748b;font-size:.875rem">₵<%= fmt(avg) %></td>
                <td>
                  <div style="display:flex;align-items:center;gap:.625rem">
                    <div style="flex:1;height:8px;background:#f1f5f9;border-radius:99px;overflow:hidden">
                      <div style="height:100%;width:<%= pct.toFixed(1) %>%;background:<%= isUnassigned ? '#e2e8f0' : '#6366f1' %>;border-radius:99px;transition:width .4s ease"></div>
                    </div>
                    <span style="font-size:.78rem;font-weight:600;color:#64748b;min-width:38px;text-align:right"><%= pct.toFixed(1) %>%</span>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
            <tfoot>
              <tr style="border-top:2px solid #e8edf5">
                <td colspan="2" style="padding:.875rem 1rem;font-weight:700;color:#0f172a">Total</td>
                <td class="col-right" style="font-weight:700;color:#0f172a;padding:.875rem 1rem"><%= totalClients %></td>
                <td class="col-right" style="font-weight:700;color:#059669;padding:.875rem 1rem"><%= rows.reduce((s,r) => s + r.activeCount, 0) %></td>
                <td class="col-right" style="font-weight:800;color:#6366f1;font-size:1rem;padding:.875rem 1rem">₵<%= fmt(grandTotal) %></td>
                <td colspan="2" style="padding:.875rem 1rem"></td>
              </tr>
            </tfoot>
          </table>
        </div>
        <% } %>
      </div>

    </div>
  </div>
</div>

<!-- ── Mobile nav ─────────────────────────────── -->
<div class="sidebar-backdrop" id="sidebarBackdrop" onclick="closeSidebar()"></div>
<nav class="mobile-nav">
  <a href="/dashboard" class="mobile-nav-item" data-path="/dashboard">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75">
      <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
      <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
    </svg>
    Home
  </a>
  <a href="/clients" class="mobile-nav-item" data-path="/clients">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75">
      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
    </svg>
    Clients
  </a>
  <a href="/branches" class="mobile-nav-item active" data-path="/branches">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75">
      <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
      <polyline points="9 22 9 12 15 12 15 22"/>
    </svg>
    Branches
  </a>
  <button class="mobile-nav-item" onclick="openSidebar()">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75">
      <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
    Menu
  </button>
</nav>

<script>
  (function () {
    var path = window.location.pathname;
    document.querySelectorAll('.mobile-nav-item[data-path]').forEach(function (item) {
      if (path === item.dataset.path || path.startsWith(item.dataset.path + '/')) {
        item.classList.add('active');
      }
    });
  })();
  function openSidebar()  { document.getElementById('sidebar').classList.add('open'); document.getElementById('sidebarBackdrop').classList.add('open'); document.body.style.overflow = 'hidden'; }
  function closeSidebar() { document.getElementById('sidebar').classList.remove('open'); document.getElementById('sidebarBackdrop').classList.remove('open'); document.body.style.overflow = ''; }
</script>
<script src="/js/modal.js"></script>
</body>
</html>
