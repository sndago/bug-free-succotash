<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cone — Activity Logs</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/client.css">
  <style>
    .log-action-badge {
      display: inline-flex; align-items: center; gap: .3rem;
      padding: .2rem .55rem; border-radius: .375rem;
      font-size: .7rem; font-weight: 700; letter-spacing: .03em; text-transform: uppercase;
    }
    .log-action-badge.auth      { background:#ede9fe; color:#6d28d9; }
    .log-action-badge.client    { background:#dbeafe; color:#1d4ed8; }
    .log-action-badge.txn       { background:#d1fae5; color:#065f46; }
    .log-action-badge.txn-warn  { background:#fff7ed; color:#c2410c; }
    .log-action-badge.edit      { background:#fef9c3; color:#854d0e; }
    .log-action-badge.user-mgmt { background:#fce7f3; color:#9d174d; }
    .log-action-badge.danger    { background:#fee2e2; color:#b91c1c; }

    .log-meta { font-size:.75rem; color:#94a3b8; margin-top:.15rem; }
    .log-desc { font-size:.85rem; color:#0f172a; }
    .log-ip   { font-family:monospace; font-size:.75rem; color:#94a3b8; }

    .filter-bar {
      display: flex; flex-wrap: wrap; gap: .75rem; align-items: flex-end;
      background: #f8fafc; border: 1px solid #e2e8f0; border-radius: .75rem;
      padding: 1rem 1.25rem; margin-bottom: 1.25rem;
    }
    .filter-bar label { display:block; font-size:.75rem; font-weight:600; color:#64748b; margin-bottom:.3rem; }
    .filter-bar input, .filter-bar select {
      height: 2.1rem; padding: 0 .625rem; border: 1.5px solid #e2e8f0; border-radius: .5rem;
      font-size: .8rem; color: #0f172a; background: #fff; font-family: inherit;
    }
    .filter-bar input:focus, .filter-bar select:focus { outline: none; border-color: #6366f1; }
    .filter-bar .filter-field { display:flex; flex-direction:column; }
    .filter-bar .filter-field.wide input,
    .filter-bar .filter-field.wide select { min-width:180px; }
    .btn-filter {
      height: 2.1rem; padding: 0 1rem; background: #6366f1; color: #fff;
      border: none; border-radius: .5rem; font-size: .8rem; font-weight: 600;
      cursor: pointer; font-family: inherit; align-self: flex-end;
    }
    .btn-filter:hover { background: #4f46e5; }
    .btn-clear {
      height: 2.1rem; padding: 0 .875rem; background: transparent; color: #64748b;
      border: 1.5px solid #e2e8f0; border-radius: .5rem; font-size: .8rem; font-weight: 500;
      cursor: pointer; font-family: inherit; text-decoration: none; display:inline-flex; align-items:center;
    }
    .btn-clear:hover { border-color: #94a3b8; color: #334155; }

    .pagination { display:flex; align-items:center; gap:.5rem; justify-content:center; padding:1rem 0 .25rem; }
    .page-btn {
      min-width:2rem; height:2rem; padding:0 .6rem; border:1.5px solid #e2e8f0;
      border-radius:.5rem; font-size:.8rem; font-weight:500; color:#334155;
      background:#fff; cursor:pointer; font-family:inherit; text-decoration:none;
      display:inline-flex; align-items:center; justify-content:center;
    }
    .page-btn:hover { border-color:#6366f1; color:#6366f1; }
    .page-btn.active { background:#6366f1; color:#fff; border-color:#6366f1; }
    .page-btn.disabled { opacity:.4; pointer-events:none; }
    .page-info { font-size:.8rem; color:#64748b; padding:0 .5rem; }

    .empty-logs { text-align:center; padding:3rem 1rem; color:#94a3b8; }
    .empty-logs svg { margin-bottom:.75rem; opacity:.4; }
  </style>
</head>
<body>
<%
  const roleLabels = { super_admin: 'Super Admin', admin: 'Admin', teller: 'Teller' };
  const fmtDate    = d => new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  const fmtTime    = d => new Date(d).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit' });

  const ACTION_CONFIG = {
    LOGIN:        { label: 'Login',          cls: 'auth' },
    LOGOUT:       { label: 'Logout',         cls: 'auth' },
    CLIENT_CREATE:{ label: 'Client Created', cls: 'client' },
    CLIENT_UPDATE:{ label: 'Client Updated', cls: 'client' },
    CLIENT_DELETE:{ label: 'Client Deleted', cls: 'danger' },
    TXN_CREATE:   { label: 'Transaction',    cls: 'txn' },
    TXN_REQUEST:  { label: 'Txn Request',    cls: 'edit' },
    TXN_UPDATE:   { label: 'Txn Updated',    cls: 'txn' },
    TXN_DELETE:   { label: 'Txn Deleted',    cls: 'danger' },
    TXN_APPROVE:  { label: 'Approved',       cls: 'txn' },
    TXN_REJECT:   { label: 'Rejected',       cls: 'txn-warn' },
    EDIT_REQUEST: { label: 'Edit Request',   cls: 'edit' },
    EDIT_APPROVE: { label: 'Edit Approved',  cls: 'txn' },
    EDIT_REJECT:  { label: 'Edit Rejected',  cls: 'txn-warn' },
    USER_CREATE:  { label: 'User Created',   cls: 'user-mgmt' },
    USER_UPDATE:  { label: 'User Updated',   cls: 'user-mgmt' },
    USER_TOGGLE:  { label: 'User Toggled',   cls: 'user-mgmt' },
    USER_DELETE:  { label: 'User Deleted',   cls: 'danger' },
  };

  const buildQuery = (overrides = {}) => {
    const p = { ...filters, ...overrides };
    const qs = Object.entries(p).filter(([,v]) => v).map(([k,v]) => `${k}=${encodeURIComponent(v)}`).join('&');
    return qs ? '?' + qs : '';
  };
%>
<div class="layout">

  <!-- ── Sidebar ──────────────────────────────── -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <svg viewBox="0 0 40 40" width="26" height="26" fill="none">
        <polygon points="20,3 38,37 2,37" fill="#6366f1"/>
      </svg>
      <span class="logo-text">CONE</span>
    </div>
    <nav class="sidebar-nav">
      <a href="/dashboard" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
        Dashboard
      </a>
      <a href="/clients" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        Clients
      </a>
      <a href="/transactions" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <line x1="17" y1="7" x2="7" y2="7"/>
          <polyline points="14 4 17 7 14 10"/>
          <line x1="7" y1="17" x2="17" y2="17"/>
          <polyline points="10 14 7 17 10 20"/>
        </svg>
        Transactions
      </a>
      <a href="/requests" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
        </svg>
        Requests
      </a>
      <a href="/users" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <line x1="23" y1="11" x2="17" y2="11"/><line x1="20" y1="8" x2="20" y2="14"/>
        </svg>
        Staff
      </a>
      <a href="/logs" class="nav-link active">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
          <polyline points="10 9 9 9 8 9"/>
        </svg>
        Logs
      </a>
      <a href="/branches" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        Branches
      </a>
      <% if (user.role === 'super_admin') { %>
      <a href="/archive" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <polyline points="21 8 21 21 3 21 3 8"/>
          <rect x="1" y="3" width="22" height="5"/>
          <line x1="10" y1="12" x2="14" y2="12"/>
        </svg>
        Archive
      </a>
      <% } %>
    </nav>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.name[0].toUpperCase() %></div>
      <div class="user-info">
        <div class="user-name"><%= user.name %></div>
        <span class="role-badge <%= user.role %>"><%= roleLabels[user.role] || user.role %></span>
      </div>
    </div>
  </aside>

  <!-- ── Main Content ──────────────────────────── -->
  <div class="main-content">
    <header class="topbar">
      <div class="topbar-breadcrumb">
        <a href="/dashboard" class="back-link">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          Dashboard
        </a>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" class="breadcrumb-sep">
          <path d="M9 18l6-6-6-6"/>
        </svg>
        <span class="breadcrumb-current">Activity Logs</span>
      </div>
      <form action="/logout" method="POST">
        <button type="submit" class="btn-logout">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
          Sign out
        </button>
      </form>
    </header>

    <div class="page-content">

      <% if (flash) { %>
      <div class="flash flash-<%= flash.type %>">
        <% if (flash.type === 'success') { %>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <% } else { %>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><circle cx="12" cy="16" r=".5" fill="currentColor"/></svg>
        <% } %>
        <%= flash.message %>
      </div>
      <% } %>

      <div class="table-card">
        <div class="table-header">
          <div class="txn-header-left">
            <h3>
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" style="vertical-align:middle;margin-right:.4rem">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
              </svg>
              Activity Logs
            </h3>
          </div>
          <span style="font-size:.8rem;color:#94a3b8"><%= pagination.total.toLocaleString() %> total entries</span>
        </div>

        <!-- Filter bar -->
        <form method="GET" action="/logs">
          <div class="filter-bar">
            <div class="filter-field wide">
              <label>Staff Member</label>
              <select name="user">
                <option value="">All users</option>
                <% staffUsers.forEach(u => { %>
                <option value="<%= u._id %>" <%= filters.userId === String(u._id) ? 'selected' : '' %>>
                  <%= u.name %> (<%= roleLabels[u.role] %>)
                </option>
                <% }) %>
              </select>
            </div>
            <div class="filter-field">
              <label>Action Type</label>
              <select name="action">
                <option value="">All actions</option>
                <optgroup label="Auth">
                  <option value="LOGIN"  <%= filters.action === 'LOGIN'  ? 'selected' : '' %>>Login</option>
                  <option value="LOGOUT" <%= filters.action === 'LOGOUT' ? 'selected' : '' %>>Logout</option>
                </optgroup>
                <optgroup label="Clients">
                  <option value="CLIENT_CREATE" <%= filters.action === 'CLIENT_CREATE' ? 'selected' : '' %>>Client Created</option>
                  <option value="CLIENT_UPDATE" <%= filters.action === 'CLIENT_UPDATE' ? 'selected' : '' %>>Client Updated</option>
                  <option value="CLIENT_DELETE" <%= filters.action === 'CLIENT_DELETE' ? 'selected' : '' %>>Client Deleted</option>
                </optgroup>
                <optgroup label="Transactions">
                  <option value="TXN_CREATE"  <%= filters.action === 'TXN_CREATE'  ? 'selected' : '' %>>Transaction Recorded</option>
                  <option value="TXN_REQUEST" <%= filters.action === 'TXN_REQUEST' ? 'selected' : '' %>>Transaction Request</option>
                  <option value="TXN_APPROVE" <%= filters.action === 'TXN_APPROVE' ? 'selected' : '' %>>Transaction Approved</option>
                  <option value="TXN_REJECT"  <%= filters.action === 'TXN_REJECT'  ? 'selected' : '' %>>Transaction Rejected</option>
                  <option value="TXN_DELETE"  <%= filters.action === 'TXN_DELETE'  ? 'selected' : '' %>>Transaction Deleted</option>
                  <option value="EDIT_REQUEST" <%= filters.action === 'EDIT_REQUEST' ? 'selected' : '' %>>Edit Request</option>
                  <option value="EDIT_APPROVE" <%= filters.action === 'EDIT_APPROVE' ? 'selected' : '' %>>Edit Approved</option>
                  <option value="EDIT_REJECT"  <%= filters.action === 'EDIT_REJECT'  ? 'selected' : '' %>>Edit Rejected</option>
                </optgroup>
                <optgroup label="Staff Management">
                  <option value="USER_CREATE" <%= filters.action === 'USER_CREATE' ? 'selected' : '' %>>User Created</option>
                  <option value="USER_UPDATE" <%= filters.action === 'USER_UPDATE' ? 'selected' : '' %>>User Updated</option>
                  <option value="USER_TOGGLE" <%= filters.action === 'USER_TOGGLE' ? 'selected' : '' %>>User Toggled</option>
                  <option value="USER_DELETE" <%= filters.action === 'USER_DELETE' ? 'selected' : '' %>>User Deleted</option>
                </optgroup>
              </select>
            </div>
            <div class="filter-field">
              <label>From</label>
              <input type="date" name="from" value="<%= filters.from %>">
            </div>
            <div class="filter-field">
              <label>To</label>
              <input type="date" name="to" value="<%= filters.to %>">
            </div>
            <button type="submit" class="btn-filter">Filter</button>
            <a href="/logs" class="btn-clear">Clear</a>
          </div>
        </form>

        <% if (!logs || logs.length === 0) { %>
        <div class="empty-logs">
          <svg viewBox="0 0 24 24" width="52" height="52" fill="none" stroke="currentColor" stroke-width="1">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
          </svg>
          <p>No log entries match the current filters.</p>
        </div>
        <% } else { %>
        <div class="table-wrapper">
          <table class="clients-table txn-table">
            <thead>
              <tr>
                <th>Timestamp</th>
                <th>User</th>
                <th>Action</th>
                <th>Description</th>
                <th>IP Address</th>
              </tr>
            </thead>
            <tbody>
              <% logs.forEach(log => {
                const cfg = ACTION_CONFIG[log.action] || { label: log.action, cls: 'auth' };
              %>
              <tr>
                <td class="date-cell" style="white-space:nowrap">
                  <div class="txn-date"><%= fmtDate(log.createdAt) %></div>
                  <div class="txn-time"><%= fmtTime(log.createdAt) %></div>
                </td>
                <td>
                  <div class="client-name" style="font-size:.875rem"><%= log.userName || '—' %></div>
                  <% if (log.userRole) { %>
                  <span class="role-badge <%= log.userRole %>" style="font-size:.7rem;padding:.1rem .45rem"><%= roleLabels[log.userRole] || log.userRole %></span>
                  <% } %>
                </td>
                <td>
                  <span class="log-action-badge <%= cfg.cls %>"><%= cfg.label %></span>
                </td>
                <td>
                  <div class="log-desc"><%= log.description %></div>
                  <% if (log.meta && Object.keys(log.meta).length) { %>
                  <div class="log-meta">
                    <% if (log.meta.amount)    { %><span>₵<%= Number(log.meta.amount).toFixed(2) %></span><% } %>
                    <% if (log.meta.category)  { %><span> · <%= log.meta.category %></span><% } %>
                    <% if (log.meta.reason)    { %><span> · Reason: <%= log.meta.reason %></span><% } %>
                    <% if (log.meta.email && log.entity === 'user') { %><span> · <%= log.meta.email %></span><% } %>
                  </div>
                  <% } %>
                </td>
                <td class="log-ip"><%= log.ip || '—' %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <% if (pagination.totalPages > 1) { %>
        <div class="table-footer-bar" style="justify-content:space-between;align-items:center">
          <span class="txn-count-label">
            Showing <%= ((pagination.currentPage - 1) * pagination.pageSize) + 1 %>–<%= Math.min(pagination.currentPage * pagination.pageSize, pagination.total) %>
            of <strong><%= pagination.total.toLocaleString() %></strong>
          </span>
          <div class="pagination">
            <a href="/logs<%= buildQuery({ page: pagination.currentPage - 1 }) %>"
               class="page-btn <%= pagination.currentPage <= 1 ? 'disabled' : '' %>">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
            </a>
            <%
              const start = Math.max(1, pagination.currentPage - 2);
              const end   = Math.min(pagination.totalPages, pagination.currentPage + 2);
              for (let p = start; p <= end; p++) {
            %>
            <a href="/logs<%= buildQuery({ page: p }) %>"
               class="page-btn <%= p === pagination.currentPage ? 'active' : '' %>"><%= p %></a>
            <% } %>
            <a href="/logs<%= buildQuery({ page: pagination.currentPage + 1 }) %>"
               class="page-btn <%= pagination.currentPage >= pagination.totalPages ? 'disabled' : '' %>">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
            </a>
          </div>
        </div>
        <% } else { %>
        <div class="table-footer-bar">
          <span class="txn-count-label"><strong><%= logs.length %></strong> entr<%= logs.length !== 1 ? 'ies' : 'y' %></span>
        </div>
        <% } %>
        <% } %>
      </div>

    </div>
  </div>
</div>
<!-- ── Mobile: backdrop + drawer toggle ─────────────── -->
<div class="sidebar-backdrop" id="sidebarBackdrop" onclick="closeSidebar()"></div>

<!-- ── Mobile: bottom navigation bar ───────────────── -->
<nav class="mobile-nav">
  <a href="/dashboard" class="mobile-nav-item" data-path="/dashboard">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75">
      <rect x="3" y="3" width="7" height="7" rx="1"/>
      <rect x="14" y="3" width="7" height="7" rx="1"/>
      <rect x="3" y="14" width="7" height="7" rx="1"/>
      <rect x="14" y="14" width="7" height="7" rx="1"/>
    </svg>
    Home
  </a>
  <a href="/clients" class="mobile-nav-item" data-path="/clients">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75">
      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
      <circle cx="9" cy="7" r="4"/>
    </svg>
    Clients
  </a>
  <a href="/transactions" class="mobile-nav-item" data-path="/transactions">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75">
      <line x1="17" y1="7" x2="7" y2="7"/>
      <polyline points="14 4 17 7 14 10"/>
      <line x1="7" y1="17" x2="17" y2="17"/>
      <polyline points="10 14 7 17 10 20"/>
    </svg>
    Txns
  </a>
  <button class="mobile-nav-item" onclick="openSidebar()">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75">
      <line x1="3" y1="6" x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
    Menu
  </button>
</nav>

<script>
  // Mark active bottom nav item by current URL path
  (function () {
    var path = window.location.pathname;
    document.querySelectorAll('.mobile-nav-item[data-path]').forEach(function (item) {
      if (path === item.dataset.path || path.startsWith(item.dataset.path + '/')) {
        item.classList.add('active');
      }
    });
  })();

  function openSidebar() {
    document.getElementById('sidebar').classList.add('open');
    document.getElementById('sidebarBackdrop').classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeSidebar() {
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sidebarBackdrop').classList.remove('open');
    document.body.style.overflow = '';
  }
</script>

<script src="/js/modal.js"></script>
</body>
</html>
