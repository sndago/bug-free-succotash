<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cone — <%= client.name %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/client.css">
  <link rel="stylesheet" href="/css/form.css">
</head>
<body>
<%
  const roleLabels = { super_admin: 'Super Admin', admin: 'Admin', teller: 'Teller' };
  const initials   = client.name.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase();
  const fmt        = n => Number(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const fmtDate    = d => new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  const fmtTime    = d => new Date(d).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
  const periodLabel = range === 'all' ? 'All Time' : `${range}d`;
%>

<div class="layout">

  <!-- ── Sidebar ──────────────────────────────── -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <svg viewBox="0 0 40 40" width="26" height="26" fill="none">
        <polygon points="20,3 38,37 2,37" fill="#6366f1"/>
      </svg>
      <span class="logo-text">CONE</span>
    </div>
    <nav class="sidebar-nav">
      <a href="/dashboard" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
        Dashboard
      </a>
      <a href="/clients" class="nav-link active">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        Clients
      </a>
      <a href="/transactions" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <line x1="17" y1="7" x2="7" y2="7"/>
          <polyline points="14 4 17 7 14 10"/>
          <line x1="7" y1="17" x2="17" y2="17"/>
          <polyline points="10 14 7 17 10 20"/>
        </svg>
        Transactions
      </a>
      <% if (['admin','super_admin'].includes(user.role)) { %>
      <a href="/requests" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
        </svg>
        Requests
      </a>
      <a href="/users" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <line x1="23" y1="11" x2="17" y2="11"/><line x1="20" y1="8" x2="20" y2="14"/>
        </svg>
        Staff
      </a>
      <a href="/logs" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
        </svg>
        Logs
      </a>
      <% } %>
      <% if (user.role === 'super_admin') { %>
      <a href="/archive" class="nav-link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
          <polyline points="21 8 21 21 3 21 3 8"/>
          <rect x="1" y="3" width="22" height="5"/>
          <line x1="10" y1="12" x2="14" y2="12"/>
        </svg>
        Archive
      </a>
      <% } %>
    </nav>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.name[0].toUpperCase() %></div>
      <div class="user-info">
        <div class="user-name"><%= user.name %></div>
        <span class="role-badge <%= user.role %>"><%= roleLabels[user.role] || user.role %></span>
      </div>
    </div>
  </aside>

  <!-- ── Main Content ──────────────────────────── -->
  <div class="main-content">

    <!-- Topbar -->
    <header class="topbar">
      <div class="topbar-breadcrumb">
        <a href="/dashboard" class="back-link">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          Dashboard
        </a>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" class="breadcrumb-sep">
          <path d="M9 18l6-6-6-6"/>
        </svg>
        <span class="breadcrumb-current"><%= client.name %></span>
      </div>
      <div class="topbar-actions">
        <button onclick="window.print()" class="btn-print">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.5">
            <polyline points="6 9 6 2 18 2 18 9"/>
            <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
            <rect x="6" y="14" width="12" height="8"/>
          </svg>
          Print Statement
        </button>
        <% if (['admin','super_admin'].includes(user.role)) { %>
        <div class="client-actions">
          <a href="/clients/<%= client._id %>/edit" class="btn-edit">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
            Edit
          </a>
          <% if (user.role === 'super_admin') { %>
          <form action="/clients/<%= client._id %>/delete" method="POST"
                data-confirm="Archive <%= client.name %>'s account? It will be permanently deleted after 60 days."
                data-confirm-title="Archive Client"
                data-confirm-danger
                data-confirm-ok="Yes, archive">
            <button type="submit" class="btn-delete">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5">
                <polyline points="3 6 5 6 21 6"/>
                <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                <path d="M10 11v6"/><path d="M14 11v6"/>
                <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
              </svg>
              Delete
            </button>
          </form>
          <% } %>
        </div>
        <% } %>
        <form action="/logout" method="POST">
          <button type="submit" class="btn-logout">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
              <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            Sign out
          </button>
        </form>
      </div>
    </header>

    <div class="page-content">
      <% if (flash) { %>
      <div class="flash flash-<%= flash.type %>">
        <% if (flash.type === 'success') { %>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <% } else { %>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><circle cx="12" cy="16" r=".5" fill="currentColor"/></svg>
        <% } %>
        <%= flash.message %>
      </div>
      <% } %>

      <% if (client.approvalStatus === 'pending') { %>
      <div class="flash flash-warning" style="background:#fffbeb;border-color:#f59e0b;color:#92400e">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><circle cx="12" cy="16" r=".5" fill="currentColor"/></svg>
        <% if (['admin','super_admin'].includes(user.role)) { %>
        This account is awaiting your approval. <a href="/requests?tab=accounts" style="color:#92400e;font-weight:600">Review in Requests →</a>
        <% } else { %>
        This account registration is pending admin approval. Transactions cannot be added until it's approved.
        <% } %>
      </div>
      <% } else if (client.approvalStatus === 'rejected') { %>
      <div class="flash flash-error">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><circle cx="12" cy="16" r=".5" fill="currentColor"/></svg>
        This account registration was rejected<% if (client.rejectionReason) { %>: <em><%= client.rejectionReason %></em><% } %>.
      </div>
      <% } %>

      <!-- ── Print Header (hidden on screen) ─── -->
      <div class="print-header">
        <div class="print-logo">
          <svg viewBox="0 0 40 40" width="28" height="28" fill="none">
            <polygon points="20,3 38,37 2,37" fill="#6366f1"/>
          </svg>
          <span>CONE</span>
        </div>
        <div class="print-meta">
          <h2>Account Statement</h2>
          <p>Generated <%= new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></p>
        </div>
      </div>

      <!-- ── Client Hero ────────────────────── -->
      <div class="client-hero">
        <div class="hero-avatar"><%= initials %></div>
        <div class="hero-body">
          <div class="hero-top">
            <div>
              <h1 class="hero-name"><%= client.name %></h1>
              <div class="hero-badges">
                <span class="type-badge <%= client.accountType %>"><%= client.accountType %></span>
                <span class="status-badge <%= client.status %>"><%= client.status %></span>
                <% if (client.assignedTeller) { %>
                <span class="teller-chip">
                  <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                  </svg>
                  <%= client.assignedTeller.name %>
                </span>
                <% } %>
              </div>
            </div>
          </div>
          <div class="hero-meta">
            <% if (client.email) { %>
            <span class="meta-chip">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/>
              </svg>
              <%= client.email %>
            </span>
            <% } %>
            <% if (client.phone) { %>
            <span class="meta-chip">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.65 3.38 2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.84a16 16 0 0 0 6.29 6.29l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              <%= client.phone %>
            </span>
            <% } %>
            <span class="meta-chip mono">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/>
              </svg>
              <%= client.accountNumber %>
            </span>
          </div>
        </div>
      </div>

      <!-- ── Stats ──────────────────────────── -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon indigo">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5">
              <line x1="12" y1="1" x2="12" y2="23"/>
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
          </div>
          <div>
            <div class="stat-value">₵<%= fmt(stats.balance) %></div>
            <div class="stat-label">Current Balance</div>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon green">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5">
              <line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/>
            </svg>
          </div>
          <div>
            <div class="stat-value">₵<%= fmt(stats.periodCredits) %></div>
            <div class="stat-label">Credits · <%= periodLabel %></div>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon red">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5">
              <line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/>
            </svg>
          </div>
          <div>
            <div class="stat-value">₵<%= fmt(stats.periodDebits) %></div>
            <div class="stat-label">Debits · <%= periodLabel %></div>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon blue">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
          </div>
          <div>
            <div class="stat-value"><%= stats.periodCount %></div>
            <div class="stat-label">Transactions · <%= periodLabel %></div>
          </div>
        </div>
      </div>

      <!-- ── Transaction History ─────────────── -->
      <div class="table-card">
        <div class="table-header">
          <div class="txn-header-left">
            <h3>Transaction History</h3>
            <div class="period-tabs">
              <a href="?range=30"  class="period-tab <%- range === '30'  ? 'active' : '' %>">30D</a>
              <a href="?range=90"  class="period-tab <%- range === '90'  ? 'active' : '' %>">90D</a>
              <a href="?range=365" class="period-tab <%- range === '365' ? 'active' : '' %>">1Y</a>
              <a href="?range=all" class="period-tab <%- range === 'all' ? 'active' : '' %>">All</a>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:.625rem">
            <div class="table-search">
              <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
              </svg>
              <input type="text" placeholder="Search transactions…" oninput="filterTxns(this.value)" id="txnSearch">
            </div>
            <% if (['admin','super_admin','teller'].includes(user.role) && client.approvalStatus !== 'pending' && client.approvalStatus !== 'rejected') { %>
            <a href="/clients/<%= client._id %>/transactions/new" class="btn-add-client" style="white-space:nowrap">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
              New Transaction
            </a>
            <% } %>
            <% if (['admin','super_admin'].includes(user.role)) { %>
            <a href="/requests" class="btn-requests" style="white-space:nowrap">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
              </svg>
              Requests
            </a>
            <% } %>
          </div>
        </div>

        <% if (!transactions || transactions.length === 0) { %>
        <div class="empty-state">
          <svg viewBox="0 0 24 24" width="56" height="56" fill="none" stroke="currentColor" stroke-width="1">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
          </svg>
          <p>No transactions found for this period.</p>
          <% if (range !== 'all') { %>
          <a href="?range=all" class="empty-link">View all transactions</a>
          <% } %>
        </div>
        <% } else { %>
        <div class="table-wrapper">
          <table class="clients-table txn-table" id="txnTable">
            <thead>
              <tr>
                <th>Date &amp; Time</th>
                <th>Description</th>
                <th>Reference</th>
                <th>Category</th>
                <th class="col-right">Debit</th>
                <th class="col-right">Credit</th>
                <th class="col-right">Balance</th>
                <th>Status</th>
                <% if (['admin','super_admin','teller'].includes(user.role)) { %>
                <th></th>
                <% } %>
              </tr>
            </thead>
            <tbody>
              <% transactions.forEach(txn => { %>
              <tr>
                <td class="date-cell">
                  <div class="txn-date"><%= fmtDate(txn.date) %></div>
                  <div class="txn-time"><%= fmtTime(txn.date) %></div>
                </td>
                <td>
                  <span class="client-name txn-desc"><%= txn.description %></span>
                </td>
                <td>
                  <code class="ref-code"><%= txn.reference %></code>
                </td>
                <td>
                  <span class="cat-badge cat-<%= txn.category %>"><%= txn.category %></span>
                </td>
                <td class="col-right">
                  <% if (txn.type === 'debit') { %>
                  <span class="amount-debit">−₵<%= fmt(txn.amount) %></span>
                  <% } else { %>
                  <span class="amount-nil">—</span>
                  <% } %>
                </td>
                <td class="col-right">
                  <% if (txn.type === 'credit') { %>
                  <span class="amount-credit">+₵<%= fmt(txn.amount) %></span>
                  <% } else { %>
                  <span class="amount-nil">—</span>
                  <% } %>
                </td>
                <td class="col-right">
                  <span class="balance-val">₵<%= fmt(txn.balanceAfter) %></span>
                </td>
                <td>
                  <% if (txn.pendingEdit && txn.pendingEdit.editStatus === 'pending') { %>
                  <span class="approval-badge approval-pending">
                    <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    Edit Pending
                  </span>
                  <% } else if (txn.requiresApproval && txn.approvalStatus !== 'na') { %>
                  <span class="approval-badge approval-<%= txn.approvalStatus %>">
                    <% if (txn.approvalStatus === 'pending') { %>
                    <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    Pending
                    <% } else if (txn.approvalStatus === 'approved') { %>
                    <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    Approved
                    <% } else { %>
                    <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Rejected
                    <% } %>
                  </span>
                  <% } else { %>
                  <span class="txn-status txn-status-<%= txn.status %>"><%= txn.status %></span>
                  <% } %>
                </td>
                <% if (['admin','super_admin','teller'].includes(user.role)) { %>
                <td class="txn-actions-cell">
                  <div class="txn-row-actions">
                    <% if (txn.pendingEdit && txn.pendingEdit.editStatus === 'pending' && ['admin','super_admin'].includes(user.role)) { %>
                    <!-- Admin inline approve/reject edit request -->
                    <form action="/transactions/<%= txn._id %>/approve-edit" method="POST" style="display:inline"
                          data-confirm="Approve this edit? The transaction and balance will be updated."
                          data-confirm-title="Approve Edit"
                          data-confirm-ok="Approve">
                      <button type="submit" class="btn-txn-approve" title="Approve Edit">
                        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                      </button>
                    </form>
                    <button type="button" class="btn-txn-delete" title="Reject Edit"
                            data-txn-id="<%= txn._id %>" data-desc="<%= txn.description %>"
                            data-route="edit"
                            onclick="openRejectModal(this.dataset.txnId, this.dataset.desc, this.dataset.route)">
                      <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                      </svg>
                    </button>
                    <% } else if (txn.requiresApproval && txn.approvalStatus === 'pending' && ['admin','super_admin'].includes(user.role)) { %>
                    <!-- Admin inline approve/reject new transaction request -->
                    <form action="/transactions/<%= txn._id %>/approve" method="POST" style="display:inline"
                          data-confirm="Approve this request? The client balance will be updated."
                          data-confirm-title="Approve Request"
                          data-confirm-ok="Approve">
                      <button type="submit" class="btn-txn-approve" title="Approve">
                        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                      </button>
                    </form>
                    <button type="button" class="btn-txn-delete" title="Reject"
                            data-txn-id="<%= txn._id %>" data-desc="<%= txn.description %>"
                            onclick="openRejectModal(this.dataset.txnId, this.dataset.desc)">
                      <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                      </svg>
                    </button>
                    <% } else { %>
                    <%
                      const isAdminUser  = ['admin','super_admin'].includes(user.role);
                      const withinDay    = (Date.now() - new Date(txn.createdAt).getTime()) < 86400000;
                      const ownPending   = txn.requiresApproval && txn.approvalStatus === 'pending' && String(txn.requestedBy) === String(user.id);
                      const ownEditPend  = txn.pendingEdit?.editStatus === 'pending' && String(txn.pendingEdit?.requestedBy) === String(user.id);
                      const isTellerUser = user.role === 'teller';
                      // Tellers can directly edit: own pending requests, or completed txns within 24h
                      const canEdit      = isAdminUser || ownPending || (!txn.requiresApproval && withinDay);
                      // Tellers can request an edit for completed txns older than 24h (not already pending)
                      const canReqEdit   = isTellerUser && !withinDay && !txn.requiresApproval && !ownEditPend && !ownPending;
                    %>
                    <% if (ownEditPend) { %>
                    <a href="/clients/<%= client._id %>/transactions/<%= txn._id %>/edit"
                       class="btn-txn-edit" title="Update Edit Request">
                      <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                      </svg>
                    </a>
                    <% } else if (canEdit) { %>
                    <a href="/clients/<%= client._id %>/transactions/<%= txn._id %>/edit"
                       class="btn-txn-edit" title="Edit">
                      <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                      </svg>
                    </a>
                    <% } else if (canReqEdit) { %>
                    <a href="/clients/<%= client._id %>/transactions/<%= txn._id %>/edit"
                       class="btn-txn-edit btn-req-edit" title="Request Edit">
                      <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                      </svg>
                    </a>
                    <% } %>
                    <% } %>
                    <% if (user.role === 'super_admin') { %>
                    <form action="/clients/<%= client._id %>/transactions/<%= txn._id %>/delete"
                          method="POST" style="display:inline"
                          data-confirm="Archive this transaction? The balance will be adjusted and it will be permanently deleted after 60 days."
                          data-confirm-title="Archive Transaction"
                          data-confirm-danger
                          data-confirm-ok="Yes, archive">
                      <button type="submit" class="btn-txn-delete" title="Delete">
                        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2">
                          <polyline points="3 6 5 6 21 6"/>
                          <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                          <path d="M10 11v6"/><path d="M14 11v6"/>
                        </svg>
                      </button>
                    </form>
                    <% } %>
                  </div>
                </td>
                <% } %>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <div class="table-footer-bar">
          <span class="txn-count-label">
            <strong><%= transactions.length %></strong> transaction<%= transactions.length !== 1 ? 's' : '' %>
            &nbsp;·&nbsp; Credits <strong>₵<%= fmt(stats.periodCredits) %></strong>
            &nbsp;·&nbsp; Debits <strong>₵<%= fmt(stats.periodDebits) %></strong>
          </span>
        </div>
        <% } %>
      </div>

    </div><!-- /page-content -->
  </div><!-- /main-content -->
</div><!-- /layout -->

<script>
  function filterTxns(q) {
    const term = q.toLowerCase();
    document.querySelectorAll('#txnTable tbody tr').forEach(row => {
      row.style.display = row.textContent.toLowerCase().includes(term) ? '' : 'none';
    });
  }

  function openRejectModal(txnId, desc, route) {
    document.getElementById('rejectTxnId').value  = txnId;
    document.getElementById('rejectDesc').textContent = desc;
    document.getElementById('rejectReason').value = '';
    document.getElementById('rejectForm').dataset.route = route || '';
    document.getElementById('rejectModal').classList.add('open');
  }
  function closeRejectModal() {
    document.getElementById('rejectModal').classList.remove('open');
  }
  document.getElementById('rejectModal')?.addEventListener('click', function(e) {
    if (e.target === this) closeRejectModal();
  });
</script>

<!-- Reject modal -->
<div id="rejectModal" class="modal-overlay">
  <div class="modal-box">
    <div class="modal-header">
      <h3>Reject Request</h3>
      <button class="modal-close" onclick="closeRejectModal()">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <p class="modal-desc">Rejecting: <strong id="rejectDesc"></strong></p>
    <form id="rejectForm" method="POST">
      <input type="hidden" name="_txnId" id="rejectTxnId">
      <div class="form-group" style="margin-bottom:1rem">
        <label for="rejectReason" style="font-size:.85rem;font-weight:600;color:#374151">Reason <span class="req">*</span></label>
        <textarea id="rejectReason" name="reason" rows="3"
          placeholder="Explain why this request is being rejected…"
          style="width:100%;resize:vertical;padding:.625rem .75rem;border:1.5px solid #e2e8f0;border-radius:.5rem;font-size:.875rem;font-family:inherit"
          required></textarea>
      </div>
      <div style="display:flex;gap:.75rem;justify-content:flex-end">
        <button type="button" onclick="closeRejectModal()" class="btn-cancel-form">Cancel</button>
        <button type="submit" class="btn-delete">Reject Request</button>
      </div>
    </form>
  </div>
</div>

<script>
  document.getElementById('rejectForm')?.addEventListener('submit', function() {
    const id    = document.getElementById('rejectTxnId').value;
    const route = this.dataset.route === 'edit' ? 'reject-edit' : 'reject';
    this.action = '/transactions/' + id + '/' + route;
  });
</script>
<style>
  /* Client detail: hero + stats stay fixed; only the transaction list scrolls */
  .client-hero { flex-shrink: 0; }
</style>
<!-- ── Mobile: backdrop + drawer toggle ─────────────── -->
<div class="sidebar-backdrop" id="sidebarBackdrop" onclick="closeSidebar()"></div>

<!-- ── Mobile: bottom navigation bar ───────────────── -->
<nav class="mobile-nav">
  <a href="/dashboard" class="mobile-nav-item" data-path="/dashboard">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75">
      <rect x="3" y="3" width="7" height="7" rx="1"/>
      <rect x="14" y="3" width="7" height="7" rx="1"/>
      <rect x="3" y="14" width="7" height="7" rx="1"/>
      <rect x="14" y="14" width="7" height="7" rx="1"/>
    </svg>
    Home
  </a>
  <a href="/clients" class="mobile-nav-item" data-path="/clients">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75">
      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
      <circle cx="9" cy="7" r="4"/>
    </svg>
    Clients
  </a>
  <a href="/transactions" class="mobile-nav-item" data-path="/transactions">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75">
      <line x1="17" y1="7" x2="7" y2="7"/>
      <polyline points="14 4 17 7 14 10"/>
      <line x1="7" y1="17" x2="17" y2="17"/>
      <polyline points="10 14 7 17 10 20"/>
    </svg>
    Txns
  </a>
  <button class="mobile-nav-item" onclick="openSidebar()">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75">
      <line x1="3" y1="6" x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
    Menu
  </button>
</nav>

<script>
  // Mark active bottom nav item by current URL path
  (function () {
    var path = window.location.pathname;
    document.querySelectorAll('.mobile-nav-item[data-path]').forEach(function (item) {
      if (path === item.dataset.path || path.startsWith(item.dataset.path + '/')) {
        item.classList.add('active');
      }
    });
  })();

  function openSidebar() {
    document.getElementById('sidebar').classList.add('open');
    document.getElementById('sidebarBackdrop').classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeSidebar() {
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sidebarBackdrop').classList.remove('open');
    document.body.style.overflow = '';
  }
</script>

<script src="/js/modal.js"></script>
</body>
</html>
